# ── GDLP CRM - Variables de Entorno ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de Datos ────────────────────────────────────────────────────────────
DB_PATH=./data/gdlp-crm.db

# ── Seguridad ────────────────────────────────────────────────────────────────
SESSION_SECRET=cambiar_esto_por_un_secreto_seguro
JWT_SECRET=cambiar_esto_por_un_jwt_secreto
JWT_EXPIRY=24h

# ── PlacetaID (integración con gateway existente) ────────────────────────────
PLACETAID_API_URL=https://id.laplaceta.org/api
PLACETAID_AUTH_URL=https://id.laplaceta.org
PLACETAID_CLIENT_ID=ccb611655030bdadf7218418dc195dcb
PLACETAID_CLIENT_SECRET=ccb611655030bdadf7218418dc195dcb

# ── Notificaciones ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATIONS_ENABLED=false

# ── Firma Digital ────────────────────────────────────────────────────────────
FIRMA_PRIVATE_KEY_PATH=./data/firma_privada.pem
FIRMA_PUBLIC_KEY_PATH=./data/firma_publica.pem
FIRMA_PASSPHRASE=
