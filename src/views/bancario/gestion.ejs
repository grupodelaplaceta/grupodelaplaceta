<div class="dashboard">
  <div class="dashboard-header">
    <h1>🏦 Gestión Bancaria</h1>
    <p class="dashboard-date">Core Bancario · Divisa Placeta (Pz) · Emisión y control monetario</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card stat-primary"><div class="stat-icon">🏦</div><div class="stat-content"><span class="stat-value" id="kpiCuentas">—</span><span class="stat-label">Cuentas</span></div></div>
    <div class="stat-card stat-success"><div class="stat-icon">💰</div><div class="stat-content"><span class="stat-value" id="kpiMasa">—</span><span class="stat-label">Masa Monetaria</span></div></div>
    <div class="stat-card stat-info"><div class="stat-icon">📊</div><div class="stat-content"><span class="stat-value" id="kpiTx">—</span><span class="stat-label">Transacciones</span></div></div>
    <div class="stat-card stat-warning"><div class="stat-icon">🏛️</div><div class="stat-content"><span class="stat-value" id="kpiTesoro">—</span><span class="stat-label">Tesorería</span></div></div>
  </div>

  <div class="section">
    <h2>🪙 Emisión / Quema Monetaria</h2>
    <div class="stats-grid">
      <div class="stat-card">
        <form id="emisionForm" style="width:100%">
          <h3 style="margin-bottom:12px">Emitir Placetas</h3>
          <div class="form-group"><label>Cantidad</label><input type="number" name="cantidad" min="1" required placeholder="10000"></div>
          <div class="form-group"><label>DIP destino</label><input type="text" name="destino_dip" required placeholder="00000000A"></div>
          <div class="form-group"><label>Motivo</label><input type="text" name="motivo" placeholder="Pago de nóminas"></div>
          <button type="submit" class="btn btn-success btn-block">Emitir</button>
        </form>
      </div>
      <div class="stat-card">
        <form id="quemaForm" style="width:100%">
          <h3 style="margin-bottom:12px">🔥 Quemar Placetas</h3>
          <div class="form-group"><label>ID Cuenta</label><input type="number" name="cuenta_id" required></div>
          <div class="form-group"><label>Cantidad</label><input type="number" name="cantidad" min="1" required></div>
          <div class="form-group"><label>Motivo</label><input type="text" name="motivo" placeholder="Exceso de capital"></div>
          <button type="submit" class="btn btn-danger btn-block">Quemar</button>
        </form>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>📋 Cuentas por Tipo</h2>
    <div class="table-container"><table class="data-table"><thead><tr><th>Tipo</th><th>Cuentas</th><th>Saldo Total</th><th>Promedio</th></tr></thead><tbody id="cuentasBody"><tr><td colspan="4">Cargando...</td></tr></tbody></table></div>
  </div>
</div>

<script>
  async function load() {
    try {
      const [resumen, cuentas] = await Promise.all([
        apiFetch('/api/bancario-proxy/resumen'),
        apiFetch('/api/bancario-proxy/resumen-cuentas')
      ]);
      document.getElementById('kpiCuentas').textContent = resumen.totalCuentas || '—';
      document.getElementById('kpiMasa').textContent = formatPz(resumen.masaMonetaria || resumen.saldoTotal || 0);
      document.getElementById('kpiTx').textContent = resumen.totalTransacciones || '—';
      document.getElementById('kpiTesoro').textContent = formatPz(resumen.tesoro || 0);
      const tb = document.getElementById('cuentasBody');
      tb.innerHTML = (cuentas || []).map(c => '<tr><td><strong>'+(c.tipo_cuenta||'—')+'</strong></td><td>'+(c.total||0)+'</td><td>'+formatPz(c.saldo_total||0)+'</td><td>'+(c.total>0?formatPz((c.saldo_total||0)/c.total):'—')+'</td></tr>').join('') || '<tr><td colspan="4">Sin datos</td></tr>';
    } catch(e) { console.error(e); }
  }

  document.getElementById('emisionForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button'); btn.disabled = true; btn.textContent='Emitiendo...';
    try {
      const data = Object.fromEntries(new FormData(e.target));
      const result = await apiFetch('/api/bancario/emision', {method:'POST', body:JSON.stringify(data)});
      mostrarMensaje('success', result.message);
      if(result.detalle) mostrarMensaje('info', `Tesoro: ${result.detalle.al_tesoro} · Admin: ${result.detalle.a_administracion} · Destino: ${result.detalle.al_destino}`);
      e.target.reset(); load();
    } catch(err) { mostrarMensaje('error', err.message); }
    finally { btn.disabled=false; btn.textContent='Emitir'; }
  });

  document.getElementById('quemaForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button'); btn.disabled = true; btn.textContent='Quemando...';
    try {
      const data = Object.fromEntries(new FormData(e.target));
      const result = await apiFetch('/api/bancario/quema', {method:'POST', body:JSON.stringify(data)});
      mostrarMensaje('success', result.message);
      e.target.reset(); load();
    } catch(err) { mostrarMensaje('error', err.message); }
    finally { btn.disabled=false; btn.textContent='Quemar'; }
  });

  load();
</script>
