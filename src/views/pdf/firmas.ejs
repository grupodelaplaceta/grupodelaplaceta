<h1>Documentos y Firmas <span style="color:#FF6600;font-size:.8rem">PlacetaID</span></h1>
<p class="dashboard-date">Sistema de Firma Digital vía PlacetaID · Firma manuscrita con validez eIDAS</p>

<div class="section">
  <h2>📋 Pendientes de Firma</h2>
  <div class="table-container"><table class="data-table"><thead><tr><th>Código</th><th>Título</th><th>Creado</th><th>Estado</th><th>Acción</th></tr></thead><tbody id="firmasPendientes"><tr><td colspan="5">Cargando...</td></tr></tbody></table></div>
</div>

<div class="section">
  <h2>✅ Documentos Firmados</h2>
  <div class="table-container"><table class="data-table"><thead><tr><th>Código</th><th>Título</th><th>Firmado por</th><th>Fecha</th><th>Hash</th><th>Acciones</th></tr></thead><tbody id="firmasCompletadas"><tr><td colspan="6">Cargando...</td></tr></tbody></table></div>
</div>

<script>
  async function cargarDocumentos() {
    try {
      const docs = await apiFetch('/api/firma/documentos');
      const pendientes = docs.filter(d => d.estado === 'pendiente');
      document.getElementById('firmasPendientes').innerHTML = pendientes.length === 0
        ? '<tr><td colspan="5">Sin documentos pendientes</td></tr>'
        : pendientes.map(d => `<tr>
          <td><span class="badge">${d.codigo_modelo}</span></td>
          <td>${d.titulo_documento}</td>
          <td>${formatFecha(d.creado_en)}</td>
          <td><span class="badge" style="background:var(--warning);color:#fff">pendiente</span></td>
          <td><button class="btn btn-success btn-sm" onclick="solicitarFirmaPlacetaID('${d.codigo_modelo}','${d.titulo_documento}')">✍️ Firmar vía PlacetaID</button></td>
        </tr>`).join('');

      const firmados = docs.filter(d => d.estado === 'firmado');
      document.getElementById('firmasCompletadas').innerHTML = firmados.length === 0
        ? '<tr><td colspan="6">Sin documentos firmados</td></tr>'
        : firmados.map(d => `<tr>
          <td><span class="badge">${d.codigo_modelo}</span></td>
          <td>${d.titulo_documento}</td>
          <td>${d.firmante_alias || d.firmado_por || '—'}</td>
          <td>${d.fecha_firma ? formatFecha(d.fecha_firma) : formatFecha(d.creado_en)}</td>
          <td style="font-size:11px;font-family:monospace">${(d.firma_hash||'').substring(0,12)}...</td>
          <td style="display:flex;gap:6px">
            <a href="/api/junior/documento-verificable/${d.id}" target="_blank" class="btn btn-sm btn-glass">📄 Ver PDF</a>
            <button class="btn btn-sm btn-outline" onclick="verificar(${d.id})">🔍</button>
          </td>
        </tr>`).join('');
    } catch(e) { console.error(e); }
  }

  async function solicitarFirmaPlacetaID(codigo, titulo) {
    const dip = prompt('DIP del firmante (tutor/ciudadano):');
    if (!dip) return;
    try {
      const result = await apiFetch('/api/firma/firmar-manuscrito', {
        method:'POST',
        body:JSON.stringify({ codigo_modelo:codigo, firmante_dip:dip, firmante_nombre:'Admin CRM', firma_base64:'admin-approval' })
      });
      if (result.success) { mostrarMensaje('success', `Firmado por ${dip}`); cargarDocumentos(); }
      else mostrarMensaje('error', result.error || 'Error');
    } catch(e) { mostrarMensaje('error', e.message); }
  }

  async function verificar(id) {
    try {
      const result = await apiFetch(`/api/firma/verificar/${id}`);
      mostrarMensaje(result.valido ? 'success' : 'error', result.valido ? 'Documento VÁLIDO' : 'NO válido');
    } catch(e) { mostrarMensaje('error', e.message); }
  }

  cargarDocumentos();
</script>
