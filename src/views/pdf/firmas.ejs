<div class="dashboard">
  <div class="dashboard-header" style="display:flex;align-items:center;gap:16px">
    <div style="width:64px;height:64px;background:linear-gradient(135deg,var(--p700),var(--p500));border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:32px;box-shadow:0 4px 16px rgba(90,47,194,.3)">🏛️</div>
    <div>
      <h1 style="margin:0">Documentos y Firmas</h1>
      <p class="dashboard-date" style="margin:2px 0 0">Sistema de Firma Digital · Grupo de La Placeta · 2026</p>
    </div>
  </div>

  <div class="section" style="margin-top:24px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
      <h2 style="margin:0;font-size:18px">📋 Pendientes de Firma</h2>
      <span class="badge" id="pendientesCount" style="background:var(--warning);color:#fff">0</span>
    </div>
    <div class="table-container">
      <table class="data-table">
        <thead><tr><th>Código</th><th>Documento</th><th>Creado</th><th>Estado</th><th>Firmar</th></tr></thead>
        <tbody id="firmasPendientes"><tr><td colspan="5" class="loading-cell">Cargando...</td></tr></tbody>
      </table>
    </div>
  </div>

  <div class="section">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
      <h2 style="margin:0;font-size:18px">✅ Documentos Firmados</h2>
      <span class="badge" id="firmadosCount" style="background:var(--green);color:#fff">0</span>
    </div>
    <div class="table-container">
      <table class="data-table">
        <thead><tr><th>Código</th><th>Documento</th><th>Firmado por</th><th>Fecha</th><th>Validación</th><th>Acciones</th></tr></thead>
        <tbody id="firmasCompletadas"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody>
      </table>
    </div>
  </div>

  <div style="margin-top:24px;padding:16px 20px;background:var(--surface-glass);border-radius:var(--radius-lg);border:1px solid rgba(255,255,255,.7);display:flex;align-items:center;gap:12px;font-size:13px;color:var(--text-light)">
    <span style="font-size:24px">🔐</span>
    <span>Firma digital con validez legal conforme a <strong>eIDAS (UE 910/2014)</strong>. Los documentos firmados son verificables mediante su hash SHA-256.</span>
  </div>
</div>

<script>
  if (typeof apiFetch === 'undefined') {
    window.apiFetch = async (url, opts) => {
      const r = await fetch(url, { headers: { 'Content-Type': 'application/json' }, ...opts });
      if (!r.ok) { let m = 'HTTP ' + r.status; try { const e = await r.json(); if (e.error) m += ': ' + e.error; } catch {} throw new Error(m); }
      return r.json();
    };
    window.mostrarMensaje = (tipo, msg) => { const d = document.getElementById('mensajes'); if (!d) return alert(msg); d.innerHTML += '<div class="toast toast-' + tipo + '">' + msg + '</div>'; setTimeout(() => { const t = d.querySelector('.toast'); if (t) t.remove(); }, 4000); };
    window.formatFecha = (d) => d ? new Date(d).toLocaleDateString('es-ES') : '—';
  }

  async function cargarDocumentos() {
    try {
      const docs = await apiFetch('/api/firma/documentos');
      const pendientes = docs.filter(d => d.estado === 'pendiente');
      const firmados = docs.filter(d => d.estado === 'firmado');
      document.getElementById('pendientesCount').textContent = pendientes.length;
      document.getElementById('firmadosCount').textContent = firmados.length;

      document.getElementById('firmasPendientes').innerHTML = !pendientes.length
        ? '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">✅</div><p>Sin documentos pendientes</p></div></td></tr>'
        : pendientes.map(d => `<tr>
          <td><span class="badge badge-pendiente">${d.codigo_modelo || '—'}</span></td>
          <td><strong>${d.titulo_documento || '—'}</strong></td>
          <td>${formatFecha(d.creado_en)}</td>
          <td><span class="tag tag-gold">⏳ Pendiente</span></td>
          <td><button class="btn btn-success btn-sm" onclick="solicitarFirmaPlacetaID('${d.codigo_modelo}','${d.titulo_documento}')">✍️ Firmar</button></td>
        </tr>`).join('');

      document.getElementById('firmasCompletadas').innerHTML = !firmados.length
        ? '<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">📄</div><p>Sin documentos firmados</p></div></td></tr>'
        : firmados.map(d => `<tr>
          <td><span class="badge badge-activo">${d.codigo_modelo || '—'}</span></td>
          <td><strong>${d.titulo_documento || '—'}</strong></td>
          <td>${d.firmante_alias || d.firmado_por || '—'}</td>
          <td>${d.fecha_firma ? formatFecha(d.fecha_firma) : formatFecha(d.creado_en)}</td>
          <td><span class="tag ${(d.firma_hash || d.hash_documento) ? 'tag-green' : 'tag-gray'}">${(d.firma_hash || d.hash_documento) ? '🔐 Válido' : '⚠️ Sin hash'}</span></td>
          <td style="display:flex;gap:6px">
            <a href="/api/junior/documento-verificable/${d.id}" target="_blank" class="btn btn-sm btn-glass" title="Ver PDF">📄 PDF</a>
            <button class="btn btn-sm btn-outline" onclick="verificarDoc(${d.id})" title="Verificar integridad">🔍 Verificar</button>
          </td>
          </td>
        </tr>`).join('');
    } catch(e) { console.error('[Firmas]', e); }
  }

  async function solicitarFirmaPlacetaID(codigo, titulo) {
    const dip = prompt('DIP del firmante (tutor/ciudadano):');
    if (!dip) return;
    try {
      const result = await apiFetch('/api/firma/firmar-manuscrito', {
        method:'POST', body:JSON.stringify({ codigo_modelo:codigo, firmante_dip:dip, firmante_nombre:'Admin CRM', firma_base64:'admin-approval' })
      });
      if (result.success) { mostrarMensaje('success', `✅ Firmado por ${dip}`); cargarDocumentos(); }
      else mostrarMensaje('error', result.error || 'Error');
    } catch(e) { mostrarMensaje('error', e.message); }
  }

  async function verificarDoc(id) {
    try {
      const result = await apiFetch(`/api/firma/verificar/${id}`);
      const hash = result.firma?.hash || '';
      mostrarMensaje(result.valido ? 'success' : 'error',
        result.valido
          ? `✅ Documento VÁLIDO<br><small style="font-family:monospace;font-size:10px">SHA-256: ${hash.substring(0,20)}...</small>`
          : '❌ Documento NO VÁLIDO');
    } catch(e) { mostrarMensaje('error', e.message); }
  }

  cargarDocumentos();
</script>