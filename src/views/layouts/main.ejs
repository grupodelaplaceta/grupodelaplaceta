<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title><%= titulo %> | GDLP CRM</title>
  <link rel="stylesheet" href="/css/crm.css?v=<%= anoActual %>">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏛️</text></svg>">
</head>
<body>
  <% if (usuario) { %>
  <!-- ── Sidebar ──────────────────────────────────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/admin/dashboard" class="sidebar-brand">
        <span class="sidebar-logo">🏛️</span>
        <span class="sidebar-title">GDLP CRM</span>
      </a>
      <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Colapsar menú" id="sidebarToggle">☰</button>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-group">
        <div class="sidebar-group-title">Panel</div>
        <a href="/admin/dashboard" class="sidebar-link <%= pathActual === '/admin/dashboard' ? 'active' : '' %>">
          <span class="sl-icon">📊</span> Dashboard
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Identidad</div>
        <a href="/admin/identidad" class="sidebar-link <%= pathActual.startsWith('/admin/identidad') ? 'active' : '' %>">
          <span class="sl-icon">🆔</span> Gestión de Altas
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Económico-Financiero</div>
        <a href="/admin/bancario" class="sidebar-link <%= pathActual.startsWith('/admin/bancario') ? 'active' : '' %>">
          <span class="sl-icon">🏦</span> Bancario
        </a>
        <a href="/admin/tributos" class="sidebar-link sidebar-sub <%= pathActual.startsWith('/admin/tributos') ? 'active' : '' %>">
          <span class="sl-icon">🧾</span> Tributos
        </a>
        <a href="/admin/fiscal" class="sidebar-link <%= pathActual.startsWith('/admin/fiscal') ? 'active' : '' %>">
          <span class="sl-icon">💰</span> Fiscal
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Ocio y Cultura</div>
        <a href="/admin/ocio" class="sidebar-link <%= pathActual.startsWith('/admin/ocio') ? 'active' : '' %>">
          <span class="sl-icon">🎲</span> Ocio y Loterías
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Recursos</div>
        <a href="/admin/recursos" class="sidebar-link <%= pathActual.startsWith('/admin/recursos') ? 'active' : '' %>">
          <span class="sl-icon">🔧</span> Recursos Digitales
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Justicia</div>
        <a href="/admin/justicia" class="sidebar-link <%= pathActual.startsWith('/admin/justicia') ? 'active' : '' %>">
          <span class="sl-icon">⚖️</span> Expedientes
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Secretaría</div>
        <a href="/admin/rgpd" class="sidebar-link <%= pathActual.startsWith('/admin/rgpd') ? 'active' : '' %>">
          <span class="sl-icon">🔒</span> RGPD
        </a>
        <a href="/admin/pdf" class="sidebar-link <%= pathActual.startsWith('/admin/pdf') ? 'active' : '' %>">
          <span class="sl-icon">📄</span> Generar PDF
        </a>
        <a href="/admin/firmas" class="sidebar-link <%= pathActual.startsWith('/admin/firmas') ? 'active' : '' %>">
          <span class="sl-icon">✍️</span> Firma Digital
        </a>
        <a href="/admin/contenidos" class="sidebar-link <%= pathActual.startsWith('/admin/contenidos') ? 'active' : '' %>">
          <span class="sl-icon">📝</span> Contenidos
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Voley Club</div>
        <a href="/admin/voley-club" class="sidebar-link <%= pathActual.startsWith('/admin/voley-club') ? 'active' : '' %>">
          <span class="sl-icon">🏐</span> Voley Club
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <span class="sidebar-user-badge"><%= usuario.alias %></span>
        <span class="sidebar-user-rol"><%= usuario.rol %></span>
      </div>
      <form action="/api/auth/logout" method="POST">
        <button type="submit" class="sidebar-logout" title="Cerrar sesión">🚪 Salir</button>
      </form>
    </div>
  </aside>

  <div class="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('open')"></div>

  <!-- ── Main Content ─────────────────────────────────────────────────────── -->
  <div class="main-wrapper">
    <div class="topbar-mobile">
      <button class="hamburger" onclick="document.getElementById('sidebar').classList.toggle('open')" aria-label="Abrir menú">☰</button>
      <span class="topbar-mobile-title">🏛️ GDLP CRM</span>
      <form action="/api/auth/logout" method="POST" class="topbar-mobile-logout">
        <button type="submit" class="btn btn-sm btn-glass" style="color:white;border-color:rgba(255,255,255,0.2)">Salir</button>
      </form>
    </div>

    <main class="main-content">
      <%- body %>
    </main>

    <footer class="footer">
      <div class="footer-content">
        <span>🏛️ Grupo de La Placeta · Normativa v5.0</span>
        <span>Año <%= anoActual %> · CRM v2.0</span>
      </div>
    </footer>
  </div>

  <% } else { %>
  <main class="main-content">
    <%- body %>
  </main>
  <% } %>

  <script src="/js/crm.js"></script>
</body>
</html>
