<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title><%= titulo %> | GDLP CRM</title>
  <link rel="stylesheet" href="/css/crm.css?v=<%= anoActual %>">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏛️</text></svg>">
</head>
<body>
  <% if (usuario) { %>
  <!-- ── Sidebar ──────────────────────────────────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/admin/dashboard" class="sidebar-brand">
        <span class="sidebar-logo">🏛️</span>
        <span class="sidebar-title">GDLP CRM</span>
      </a>
      <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Colapsar menú" id="sidebarToggle">☰</button>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-group">
        <div class="sidebar-group-title">Panel</div>
        <a href="/admin/dashboard" class="sidebar-link <%= pathActual === '/admin/dashboard' ? 'active' : '' %>">
          <span class="sl-icon">📊</span> Dashboard
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Identidad</div>
        <a href="/admin/identidad" class="sidebar-link <%= pathActual.startsWith('/admin/identidad') ? 'active' : '' %>">
          <span class="sl-icon">🆔</span> Altas
        </a>
        <a href="/admin/ciudadanos" class="sidebar-link <%= pathActual.startsWith('/admin/ciudadanos') ? 'active' : '' %>">
          <span class="sl-icon">👥</span> Ciudadanos
        </a>
        <a href="/admin/placetid" class="sidebar-link <%= pathActual.startsWith('/admin/placetid') ? 'active' : '' %>">
          <span class="sl-icon">🔐</span> PlacetaID
        </a>
        <a href="/admin/placeta-junior" class="sidebar-link <%= pathActual.startsWith('/admin/placeta-junior') ? 'active' : '' %>">
          <span class="sl-icon">🌈</span> Placeta Junior
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Financiero</div>
        <a href="/admin/bancario" class="sidebar-link <%= pathActual.startsWith('/admin/bancario') ? 'active' : '' %>">
          <span class="sl-icon">🏦</span> Bancario
        </a>
        <a href="/admin/audit-bancario" class="sidebar-link <%= pathActual.startsWith('/admin/audit-bancario') ? 'active' : '' %>">
          <span class="sl-icon">🏛️</span> Gobierno
        </a>
        <a href="/admin/empresas" class="sidebar-link <%= pathActual.startsWith('/admin/empresas') ? 'active' : '' %>">
          <span class="sl-icon">🏢</span> Empresas
        </a>
        <a href="/admin/tributos" class="sidebar-link <%= pathActual.startsWith('/admin/tributos') ? 'active' : '' %>">
          <span class="sl-icon">🧾</span> Tributos
        </a>
        <a href="/admin/fiscal" class="sidebar-link <%= pathActual.startsWith('/admin/fiscal') ? 'active' : '' %>">
          <span class="sl-icon">📊</span> Fiscal
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Justicia</div>
        <a href="/admin/justicia" class="sidebar-link <%= pathActual.startsWith('/admin/justicia') ? 'active' : '' %>">
          <span class="sl-icon">⚖️</span> Expedientes
        </a>
        <a href="/admin/tramitacion" class="sidebar-link <%= pathActual.startsWith('/admin/tramitacion') ? 'active' : '' %>">
          <span class="sl-icon">📋</span> Tramitación
        </a>
        <a href="/admin/vigilancia" class="sidebar-link <%= pathActual.startsWith('/admin/vigilancia') ? 'active' : '' %>">
          <span class="sl-icon">👁️</span> Vigilancia
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Secretaría</div>
        <a href="/admin/documentos" class="sidebar-link <%= pathActual.startsWith('/admin/documentos') ? 'active' : '' %>">
          <span class="sl-icon">📄</span> Documentos
        </a>
        <a href="/admin/rgpd" class="sidebar-link <%= pathActual.startsWith('/admin/rgpd') ? 'active' : '' %>">
          <span class="sl-icon">🔒</span> RGPD
        </a>
        <a href="/admin/contenidos" class="sidebar-link <%= pathActual.startsWith('/admin/contenidos') ? 'active' : '' %>">
          <span class="sl-icon">📝</span> Contenidos
        </a>
        <a href="/admin/pdf" class="sidebar-link <%= pathActual.startsWith('/admin/pdf') ? 'active' : '' %>">
          <span class="sl-icon">📑</span> Generar PDF
        </a>
        <a href="/admin/firmas" class="sidebar-link <%= pathActual.startsWith('/admin/firmas') ? 'active' : '' %>">
          <span class="sl-icon">✍️</span> Firmas
        </a>
      </div>

      <div class="sidebar-group">
        <div class="sidebar-group-title">Grupos</div>
        <a href="/admin/ocio" class="sidebar-link <%= pathActual.startsWith('/admin/ocio') ? 'active' : '' %>">
          <span class="sl-icon">🎲</span> Ocio
        </a>
        <a href="/admin/voley-club" class="sidebar-link <%= pathActual.startsWith('/admin/voley-club') ? 'active' : '' %>">
          <span class="sl-icon">🏐</span> Voley Club
        </a>
        <a href="/admin/recursos" class="sidebar-link <%= pathActual.startsWith('/admin/recursos') ? 'active' : '' %>">
          <span class="sl-icon">🔧</span> Recursos
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <span class="sidebar-user-badge"><%= usuario.alias %></span>
        <span class="sidebar-user-rol"><%= usuario.rol %></span>
      </div>
      <div style="display:flex;gap:6px;align-items:center">
        <a href="/admin/audit-bancario" style="position:relative;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.7);padding:6px 10px;border-radius:10px;text-decoration:none;font-size:14px" title="Notificaciones">🔔 <span id="notifBadge" style="display:none;background:var(--red);color:#fff;border-radius:50%;padding:1px 5px;font-size:10px;position:absolute;top:-4px;right:-4px">0</span></a>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="sidebar-logout" title="Cerrar sesión">🚪 Salir</button>
        </form>
      </div>
    </div>
  </aside>

  <div class="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('open')"></div>

  <!-- ── Main Content ─────────────────────────────────────────────────────── -->
  <div class="main-wrapper">
    <div class="topbar-mobile">
      <button class="hamburger" onclick="document.getElementById('sidebar').classList.toggle('open')" aria-label="Abrir menú">☰</button>
      <span class="topbar-mobile-title">🏛️ GDLP CRM</span>
      <div style="display:flex;gap:6px;align-items:center">
        <button class="btn btn-sm btn-glass" style="color:white;border-color:rgba(255,255,255,0.2);position:relative" onclick="window.location.href='/admin/audit-bancario'" title="Notificaciones">
          🔔 <span id="notifBadgeMobile" style="display:none;background:var(--red);color:#fff;border-radius:50%;padding:1px 5px;font-size:10px;position:absolute;top:-2px;right:-4px">0</span>
        </button>
        <form action="/api/auth/logout" method="POST" class="topbar-mobile-logout">
          <button type="submit" class="btn btn-sm btn-glass" style="color:white;border-color:rgba(255,255,255,0.2)">Salir</button>
        </form>
      </div>
    </div>

    <main class="main-content">
      <%- body %>
    </main>

    <footer class="footer">
      <div class="footer-content">
        <span>🏛️ Grupo de La Placeta · Normativa v5.0</span>
        <span>Año <%= anoActual %> · CRM v2.0</span>
      </div>
    </footer>
  </div>

  <% } else { %>
  <main class="main-content">
    <%- body %>
  </main>
  <% } %>

  <!-- Toast notifications container -->
  <div id="mensajes"></div>

  <script src="/js/crm.js"></script>
  <script src="/js/buscador-universal.js"></script>
</body>
</html>
