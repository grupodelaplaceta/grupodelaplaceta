<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PlacetaID - Autenticación</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', system-ui, sans-serif; background: #1c005f; min-height: 100vh; display: flex; align-items: center; justify-content: center; color: #fff; }
    .callback-card { text-align: center; padding: 40px; }
    .spinner { width: 40px; height: 40px; border: 4px solid rgba(255,255,255,.2); border-top-color: #fff; border-radius: 50%; animation: spin .8s linear infinite; margin: 0 auto 16px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .callback-card p { font-size: 15px; opacity: .8; }
  </style>
</head>
<body>
  <div class="callback-card">
    <div class="spinner"></div>
    <p>Completando autenticación...</p>
  </div>

  <script>
    (function() {
      const params = new URLSearchParams(window.location.search);
      const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));
      const token = params.get('placetaid_token') || params.get('token') || params.get('access_token') || hashParams.get('token') || hashParams.get('placetaid_token') || hashParams.get('access_token');
      const userStr = params.get('user') || params.get('usuario') || params.get('userData') || hashParams.get('user') || hashParams.get('usuario') || hashParams.get('userData');
      const state = params.get('state') || hashParams.get('state');
      const error = params.get('error') || hashParams.get('error');

      if (error) {
        document.querySelector('.callback-card p').textContent = 'Error: ' + decodeURIComponent(error);
        return;
      }

      if (token) {
        try {
          const payload = { token, state };
          if (userStr) {
            payload.usuario = JSON.parse(decodeURIComponent(userStr));
          }
          fetch('/api/placetid/set-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          }).then(r => r.json()).then(function(data) {
            if (window.opener && window.opener !== window) {
              window.opener.postMessage({ tipo: 'placetaid-login', token, usuario: payload.usuario || null, state }, window.location.origin);
            }
            window.location.href = (data && data.redirect) ? data.redirect : '/';
          }).catch(function() {
            window.location.href = '/login';
          });
        } catch(e) {
          document.querySelector('.callback-card p').textContent = 'Error al procesar autenticación';
          console.error(e);
        }
      } else {
        document.querySelector('.callback-card p').textContent = 'No se recibieron datos de autenticación';
      }
    })();
  </script>
</body>
</html>
