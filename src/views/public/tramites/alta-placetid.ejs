<section class="hero" style="padding:50px 24px">
  <h1>Alta PlacetaID</h1>
  <p>Activa tu identidad digital completa</p>
</section>

<section class="section">
  <div class="section-inner tramite-form">
    <div class="form-card">
      <h2>🔑 Activar PlacetaID</h2>
      <p>Usa tu DIP provisional para activar tu PlacetaID y obtener acceso completo al ecosistema.</p>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (typeof resultado !== 'undefined' && resultado) { %>
      <div class="alert alert-success">
        <strong>✅ PlacetaID activado</strong><br><br>
        <strong>PlacetaID:</strong> <%= resultado.placeid %><br>
        <strong><%= resultado.message %></strong>
      </div>
      <a href="/login" class="btn btn-primary btn-block">Iniciar Sesión</a>
      <% } else { %>
      <form method="POST" action="/tramites/alta-placetid">
        <div class="form-group">
          <label>DIP Provisional *</label>
          <input type="text" name="dip" required placeholder="Ej: 12345678A" value="<%= typeof dipSugerido !== 'undefined' ? dipSugerido : '' %>">
          <span class="form-hint">El DIP que recibiste al solicitar el alta</span>
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" required placeholder="El email que usaste en la solicitud">
        </div>
        <div class="form-group">
          <label>Contraseña *</label>
          <input type="password" name="password" required minlength="8" placeholder="Mínimo 8 caracteres">
        </div>
        <button type="submit" class="btn btn-primary btn-block">Activar PlacetaID</button>
      </form>
      <% } %>
    </div>
  </div>
</section>
