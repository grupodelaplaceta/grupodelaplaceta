<section class="section" style="padding:40px 24px">
  <div class="section-inner">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:12px">
      <div>
        <h1 style="font-size:24px;font-weight:900;letter-spacing:-.5px">Mis Documentos</h1>
        <p style="color:var(--tm);font-size:14px">Historial de trámites y documentos generados.</p>
      </div>
      <a href="/tramites" class="btn btn-go" style="text-decoration:none;font-size:13px">➕ Nuevo trámite</a>
    </div>

    <% if (typeof docs === 'undefined' || !docs || docs.length === 0) { %>
    <div class="alert alert-i" style="text-align:center;padding:32px">
      <div style="font-size:40px;margin-bottom:12px">📄</div>
      <p style="font-size:15px;color:var(--tm)">No tienes documentos registrados.</p>
      <a href="/tramites" class="btn btn-go" style="margin-top:12px;display:inline-block;text-decoration:none">Ir a Trámites</a>
    </div>
    <% } else { %>
    <div style="display:grid;gap:8px">
      <% var iconos = { dip:'🪪', placetid:'🔑', queja:'💬', 'control-parental':'👨‍👩‍👧‍👦', entidad:'🏢', documento:'📄' }; %>
      <% var nombres = { dip:'Solicitud DIP', placetid:'Activación PlacetaID', queja:'Queja/Sugerencia', 'control-parental':'Control Parental', entidad:'Alta Entidad', documento:'Documento' }; %>
      <% docs.forEach(function(d) { %>
      <div style="display:flex;align-items:center;gap:14px;padding:14px 18px;background:var(--s);border-radius:12px;border:1px solid var(--l);transition:all .2s">
        <span style="font-size:26px;flex-shrink:0"><%= iconos[d.tipo] || '📄' %></span>
        <div style="flex:1;min-width:0">
          <strong style="font-size:14px"><%= nombres[d.tipo] || d.tipo || 'Documento' %></strong>
          <span style="display:block;font-size:12px;color:var(--tm)"><%= d.creado_en ? new Date((d.creado_en.endsWith('Z') ? d.creado_en : d.creado_en + 'Z')).toLocaleDateString('es-ES', { day:'numeric', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—' %><%= d.referencia ? ' · ' + d.referencia : '' %></span>
        </div>
        <% if (d.pdf_url) { %>
        <a href="<%= d.pdf_url %>" target="_blank" class="btn btn-sm" style="background:var(--p);color:#fff;text-decoration:none;border-radius:8px;padding:6px 14px;font-size:12px;flex-shrink:0">📄 PDF</a>
        <% } else { %>
        <span style="font-size:11px;color:var(--l);flex-shrink:0">Sin PDF</span>
        <% } %>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>
      </table>
    </div>
    <% } %>

    <div style="margin-top:24px">
      <a href="/ciudadano" class="btn btn-outline-light" style="color:var(--accent);border-color:var(--line)">← Volver a Mi Área</a>
    </div>
  </div>
</section>
