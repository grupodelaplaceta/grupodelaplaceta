<% if (!usuario) { %>
<script>window.location.href='/login?redirect=/tramites';</script>
<% } %>

<% if (usuario) { %>
<div style="background:linear-gradient(135deg, #3f00d8, #1c005f);border-radius:16px;padding:18px 24px;margin-bottom:28px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;color:#fff;box-shadow:0 4px 20px rgba(63,0,216,.25)">
  <span style="font-size:28px;width:48px;height:48px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center">👤</span>
  <div style="flex:1;min-width:160px">
    <div style="font-weight:700;font-size:16px"><%= usuario.alias || usuario.dip || 'Ciudadano' %></div>
    <div style="font-size:13px;opacity:.8"><%= usuario.dip ? 'DIP: ' + usuario.dip : '' %><% if (usuario.rol) { %> · <span style="background:rgba(255,255,255,.2);padding:1px 8px;border-radius:10px"><%= usuario.rol %></span><% } %></div>
  </div>
  <a href="/ciudadano" class="btn" style="background:#fff;color:#1c005f;padding:8px 18px;border-radius:10px;font-weight:600;text-decoration:none;font-size:13px">📁 Mis Documentos</a>
</div>
<% } else { %>
<script>window.location.href='/login?redirect=/tramites';</script>
<% } %>

<section class="hero-sm">
  <h1>📋 Trámites</h1>
  <p>Gestiona tus trámites legales y del ecosistema. Todos los archivos se guardan en <strong>Mis Documentos</strong>.</p>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     SECCIÓN: TRÁMITES LEGALES (Asociación real)
     ═══════════════════════════════════════════════════════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="aviso aviso-real">
      <span class="aviso-icon">⚖️</span>
      <div><strong>Trámite legal real.</strong> Los marcados como <strong>"Asociación"</strong> son gestiones oficiales reales sujetas a la normativa española (LOPDGDD, RGPD, Ley 1/2002).</div>
    </div>
    <h2>⚖️ Trámites <span class="a">Legales</span></h2>
    <p class="section-subtitle">Gestiones oficiales de la Asociación con plena validez jurídica real.</p>
    <div class="tramite-grid">
      <div class="tramite-group-label">📋 Documentación y registro</div>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('control-parental')">
        <div class="tramite-icon">👨‍👩‍👧‍👦</div>
        <h3>Control Parental</h3>
        <p>Registro oficial de tutor legal para menores de 16. Genera código de vinculación.</p>
        <span class="tag tag-legal">⚖️ Asociación</span>
      </a>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('recuperar-codigo')">
        <div class="tramite-icon">🔍</div>
        <h3>Recuperar Código</h3>
        <p>Recupera el código de vinculación de un menor usando tu DNI.</p>
        <span class="tag tag-legal">⚖️ Asociación</span>
      </a>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('quejas')">
        <div class="tramite-icon">💬</div>
        <h3>Quejas y Sugerencias</h3>
        <p>Canal oficial con la Junta Directiva. Registro y respuesta en plazo legal.</p>
        <span class="tag tag-legal">⚖️ Asociación</span>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     SECCIÓN: IDENTIDAD Y ACCESO (Ecosistema)
     ═══════════════════════════════════════════════════════════════════════════ -->
<section class="section">
  <div class="section-inner">
    <div class="aviso aviso-sim">
      <span class="aviso-icon">🎭</span>
      <div><strong>Entorno simulado.</strong> Los marcados como <strong>"Ecosistema"</strong> pertenecen al país ficticio de La Placeta. Sin validez jurídica real.</div>
    </div>
    <h2>🆔 Identidad y <span class="a">Acceso</span></h2>
    <p class="section-subtitle">Gestiona tu identidad digital y credenciales en La Placeta.</p>
    <div class="tramite-grid">
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('alta-dip')">
        <div class="tramite-icon">🪪</div>
        <h3>Alta DIP</h3>
        <p>Solicita tu Documento de Identidad de La Placeta.</p>
        <span class="tag tag-eco">🎭 Ecosistema</span>
      </a>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('alta-placetid')">
        <div class="tramite-icon">🔑</div>
        <h3>Alta PlacetaID</h3>
        <p>Activa tu identidad digital con un DIP provisional.</p>
        <span class="tag tag-eco">🎭 Ecosistema</span>
      </a>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('alta-entidad')">
        <div class="tramite-icon">🏢</div>
        <h3>Alta Entidad (EIP)</h3>
        <p>Registra tu empresa simulada y obtén tu EIP.</p>
        <span class="tag tag-eco">🎭 Ecosistema</span>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     SECCIÓN: FISCAL Y TRIBUTOS (Ecosistema)
     ═══════════════════════════════════════════════════════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="aviso aviso-sim">
      <span class="aviso-icon">💰</span>
      <div><strong>Gestión fiscal del ecosistema.</strong> Tributos de La Placeta (TLP) gestiona el censo, facturación e impuestos del ecosistema simulado.</div>
    </div>
    <h2>🧾 Fiscal y <span class="a">Tributos</span></h2>
    <p class="section-subtitle">Gestiona tus obligaciones fiscales en el ecosistema: censo, facturación e impuestos.</p>
    <div class="tramite-grid">
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('alta-tributos')">
        <div class="tramite-icon">🧾</div>
        <h3>Alta en Tributos</h3>
        <p>Regístrate en el censo de contribuyentes. Obligatorio para operar con tu cuenta bancaria.</p>
        <span class="tag tag-eco">💰 TLP</span>
      </a>
      <a class="tramite-card" href="javascript:void(0)" onclick="abrirTramite('solicitar-factura')">
        <div class="tramite-icon">📄</div>
        <h3>Solicitar Factura</h3>
        <p>Emite una factura con IVA del 12% y recibe tu CSV de verificación único.</p>
        <span class="tag tag-eco">💰 TLP</span>
      </a>
      <a class="tramite-card" href="/tramites/consulta-tributos">
        <div class="tramite-icon">📊</div>
        <h3>Consulta Tributaria</h3>
        <p>Revisa tu estado fiscal, declaraciones pendientes e historial de pagos.</p>
        <span class="tag tag-eco">💰 TLP</span>
      </a>
    </div>
  </div>
</section>

<% if (typeof usuario !== 'undefined' && usuario) { %>
<section class="section section-dark">
  <div class="section-inner">
    <h2>📁 Mis <span class="g">Documentos</span></h2>
    <p class="section-subtitle">Tus trámites realizados y documentos descargables.</p>
    <div id="misDocs">
      <p style="color:rgba(255,255,255,.5);text-align:center;padding:20px">Cargando documentos...</p>
    </div>
  </div>
</section>

<script>
(async function() {
  try {
    const r = await fetch('/api/tramites/mis-documentos');
    const docs = await r.json();
    const div = document.getElementById('misDocs');
    if (!docs.length) {
      div.innerHTML = '<p style="color:rgba(255,255,255,.5);text-align:center;padding:20px">No has realizado ningún trámite aún.</p>';
      return;
    }
    div.innerHTML = '<div style="display:grid;gap:10px">' + docs.map(d => {
      const fecha = new Date(d.creado_en + 'Z').toLocaleDateString('es-ES');
      const icono = d.tipo === 'dip' ? '🪪' : d.tipo === 'placetid' ? '🔑' : d.tipo === 'queja' ? '💬' : d.tipo === 'control-parental' ? '👨‍👩‍👧‍👧' : d.tipo === 'entidad' ? '🏢' : d.tipo === 'alta-tributos' ? '🧾' : d.tipo === 'solicitar-factura' ? '📄' : '📄';
      const nombre = d.tipo === 'dip' ? 'Solicitud DIP' : d.tipo === 'placetid' ? 'Activación PlacetaID' : d.tipo === 'queja' ? 'Queja/Sugerencia' : d.tipo === 'control-parental' ? 'Control Parental' : d.tipo === 'entidad' ? 'Alta Entidad' : d.tipo === 'alta-tributos' ? 'Alta en Tributos' : d.tipo === 'solicitar-factura' ? 'Solicitar Factura' : 'Trámite';
      return '<div style="background:rgba(255,255,255,.08);border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:14px">' +
        '<span style="font-size:24px">' + icono + '</span>' +
        '<div style="flex:1"><strong>' + nombre + '</strong><br><span style="font-size:12px;opacity:.6">' + fecha + (d.referencia ? ' · ' + d.referencia : '') + '</span></div>' +
        (d.pdf_url ? '<a href="' + d.pdf_url + '" target="_blank" class="btn btn-sm btn-go" style="text-decoration:none">📄 PDF</a>' : '') +
        '</div>';
    }).join('') + '</div>';
  } catch(e) {
    document.getElementById('misDocs').innerHTML = '<p style="color:rgba(255,255,255,.5);text-align:center;padding:20px">Error al cargar documentos.</p>';
  }
})();
</script>
</section>
<% } %>

<!-- Modal container -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)cerrarTramite()">
  <div class="modal-box" id="modalBox">
    <button class="modal-close" onclick="cerrarTramite()">✕</button>
    <div id="modalContent"><div style="text-align:center;padding:20px;color:var(--tm)">Cargando...</div></div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>

<script>
function abrirTramite(tramite) {
  document.getElementById('modalOverlay').classList.add('open');
  document.getElementById('modalContent').innerHTML = '<div style="text-align:center;padding:30px;color:var(--tm)">⏳ Cargando formulario...</div>';
  fetch('/api/tramites/form/' + tramite)
    .then(r => r.text())
    .then(html => {
      document.getElementById('modalContent').innerHTML = html;
      document.querySelectorAll('.cbox input').forEach(cb => {
        cb.addEventListener('change', function() {
          this.closest('.cbox').classList.toggle('checked', this.checked);
        });
      });
    })
    .catch(() => document.getElementById('modalContent').innerHTML = '<div class="alert alert-e">Error al cargar el formulario.</div>');
}
function cerrarTramite() { document.getElementById('modalOverlay').classList.remove('open'); }
function mostrarToast(tipo, texto) {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div');
  t.className = 'toast toast-' + tipo;
  t.textContent = texto;
  c.appendChild(t);
  setTimeout(() => t.remove(), 5000);
}
async function enviarForm(tramite, form) {
  const btn = form.querySelector('button[type="submit"]');
  btn.disabled = true; btn.textContent = 'Enviando...';
  const fd = new FormData(form);
  try {
    const res = await fetch('/api/tramites/submit/' + tramite, { method: 'POST', body: new URLSearchParams(fd), headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
    const data = await res.json();
    if (data.ok) {
      let html = '<div class="alert alert-s" style="margin-top:10px">' + data.msg + '</div>' + (data.html || '');
      if (data.pdf_url) html += '<div style="text-align:center;margin-top:14px"><a href="' + data.pdf_url + '" target="_blank" class="btn btn-go">📄 Descargar PDF</a></div>';
      document.getElementById('modalContent').innerHTML = html;
      mostrarToast('s', '✅ ' + data.msg);
      // Recargar lista de documentos si está visible
      setTimeout(function() { location.reload(); }, 2000);
    } else {
      mostrarToast('e', '❌ ' + (data.error || 'Error'));
    }
  } catch(e) { mostrarToast('e', '❌ Error de conexión'); }
  btn.disabled = false; btn.textContent = 'Enviar';
  return false;
}
</script>
