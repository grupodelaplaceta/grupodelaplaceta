<section class="hero" style="padding:60px 24px">
  <h1>Galería</h1>
  <p>Imágenes del ecosistema Grupo de La Placeta.</p>
</section>

<section class="section">
  <div class="section-inner">
    <h2>Capturas del <span class="accent">ecosistema</span></h2>
    <p class="section-subtitle">Momentos y escenarios de La Placeta.</p>
    <div class="gallery-grid" id="galeriaGrid"></div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', async function() {
  const resp = await fetch('/api/fotos/galeria');
  const imagenes = await resp.json();
  const grid = document.getElementById('galeriaGrid');
  imagenes.forEach(function(img) {
    var wrap = document.createElement('div');
    wrap.className = 'gallery-img-wrap';
    wrap.innerHTML = '<img class="lb-img gallery-img" src="'+img.url+'" alt="'+img.alt+'" loading="lazy" style="border:2px solid rgba(255,255,255,0.15);height:160px;width:auto" onclick="abrirLightbox(\'img\',\''+img.url.replace(/'/g,"\\'")+'\')"><button class="like-btn" data-foto="'+img.url.replace(/'/g,"\\'")+'" onclick="toggleLike(this)"><span class="like-icon">❤️</span><span class="like-count">'+img.likes+'</span></button>';
    grid.appendChild(wrap);
  });
  try {
    var lresp = await fetch('/api/fotos/likes');
    var likes = await lresp.json();
    document.querySelectorAll('.like-btn').forEach(function(btn) {
      var foto = btn.getAttribute('data-foto');
      if (likes[foto]) btn.querySelector('.like-count').textContent = likes[foto];
    });
  } catch(e) {}
});
</script>
