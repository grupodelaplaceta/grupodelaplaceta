<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> | GDLP CRM</title>
  <link rel="stylesheet" href="/css/crm.css">
</head>
<body class="auth-page">
  <div class="auth-container">
    <div class="auth-card auth-card-wide">
      <div class="auth-header">
        <div class="auth-icon">📋</div>
        <h1>Solicitud de Alta</h1>
        <p>Formulario de registro en el ecosistema</p>
        <p class="auth-subtitle">Grupo de La Placeta · Normativa v5.0</p>
      </div>
      
      <div id="successMsg" class="alert alert-success" style="display:none"></div>
      <div id="errorMsg" class="alert alert-error" style="display:none"></div>
      
      <form id="registerForm" class="auth-form">
        <div class="form-row">
          <div class="form-group">
            <label for="alias">Alias *</label>
            <input type="text" id="alias" name="alias" required placeholder="Nombre público en el ecosistema">
          </div>
          <div class="form-group">
            <label for="nombre_real">Nombre Real *</label>
            <input type="text" id="nombre_real" name="nombre_real" required placeholder="Tal cual en tu DNI real">
          </div>
        </div>
        
        <div class="form-group">
          <label for="email">Correo Electrónico *</label>
          <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com">
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="fecha_nacimiento">Fecha de Nacimiento *</label>
            <input type="date" id="fecha_nacimiento" name="fecha_nacimiento" required>
          </div>
          <div class="form-group">
            <label for="id_aval">ID de Aval (Tutor)</label>
            <input type="text" id="id_aval" name="id_aval" placeholder="Alias del tutor (solo menores de 18)">
            <small class="form-hint">Obligatorio para menores de edad</small>
          </div>
        </div>
        
        <div class="form-group">
          <label for="password">Contraseña *</label>
          <input type="password" id="password" name="password" required placeholder="Mínimo 8 caracteres" minlength="8">
        </div>
        
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" id="consentimiento" required>
            <span>Acepto la <a href="/privacidad" target="_blank">Política de Privacidad</a> y el tratamiento de mis datos personales conforme al RGPD y la LOPDGDD</span>
          </label>
        </div>

        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" id="normativa" required>
            <span>Declaro haber leído y acepto la Normativa Institucional Unificada v5.0 y los Estatutos de la Asociación Grupo de La Placeta</span>
          </label>
        </div>
        
        <button type="submit" class="btn btn-primary btn-block">
          <span class="btn-text">Solicitar Alta</span>
          <span class="btn-loading" style="display:none">Procesando...</span>
        </button>
      </form>
      
      <div class="auth-footer">
        <p>¿Ya tienes cuenta? <a href="/login">Iniciar Sesión</a></p>
        <p class="auth-note">Las solicitudes serán revisadas por la Junta Directiva en un plazo máximo de 7 días</p>
      </div>
    </div>
  </div>

  <script>
    let registroEnviado = false;

    document.getElementById('registerForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (registroEnviado) return; // ← Bloquea auto-clickers
        
      const btn = e.target.querySelector('button[type="submit"]');
      const errorMsg = document.getElementById('errorMsg');
      const successMsg = document.getElementById('successMsg');
      
      registroEnviado = true;
      btn.disabled = true;
      btn.querySelector('.btn-text').style.display = 'none';
      btn.querySelector('.btn-loading').style.display = 'inline';
      errorMsg.style.display = 'none';
      successMsg.style.display = 'none';

      try {
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        delete data.consentimiento;
        delete data.normativa;

        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        
        if (result.success) {
          successMsg.innerHTML = `<strong>¡Solicitud registrada!</strong><br>${result.message}<br><br><strong>DIP:</strong> ${result.usuario.dip}<br><strong>PlacetaID:</strong> ${result.usuario.placeid}<br><strong>Franja:</strong> ${result.usuario.franja_edad}`;
          successMsg.style.display = 'block';
          e.target.style.display = 'none';
        } else {
          errorMsg.textContent = result.error || 'Error al registrar';
          errorMsg.style.display = 'block';
          registroEnviado = false; // Solo re-permite si fue error (no 409 por duplicado real)
          btn.disabled = false;
        }
      } catch (err) {
        errorMsg.textContent = 'Error de conexión';
        errorMsg.style.display = 'block';
        registroEnviado = false;
        btn.disabled = false;
      } finally {
        btn.querySelector('.btn-text').style.display = 'inline';
        btn.querySelector('.btn-loading').style.display = 'none';
      }
    });
  </script>
</body>
</html>
