<div class="dashboard">
  <div class="dashboard-header">
    <h1>Gestión de Recursos Digitales</h1>
    <p class="dashboard-date">Módulo 5: Permisos, Credenciales y Offboarding</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card stat-primary">
      <div class="stat-icon">🔧</div>
      <div class="stat-content">
        <span class="stat-value" id="kpiRecursos">—</span>
        <span class="stat-label">Recursos</span>
        <span class="stat-detail">Asignados total</span>
      </div>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-icon">✅</div>
      <div class="stat-content">
        <span class="stat-value" id="kpiRecActivos">—</span>
        <span class="stat-label">Activos</span>
        <span class="stat-detail">En uso actual</span>
      </div>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-icon">⏳</div>
      <div class="stat-content">
        <span class="stat-value" id="kpiRecPend">—</span>
        <span class="stat-label">Pendientes</span>
        <span class="stat-detail">Por gestionar</span>
      </div>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-icon">📋</div>
      <div class="stat-content">
        <span class="stat-value" id="kpiRecTipos">—</span>
        <span class="stat-label">Tipos</span>
        <span class="stat-detail">Categorías distintas</span>
      </div>
    </div>
  </div>

<div class="stats-grid">
  <div class="stat-card">
    <form id="asignarForm" style="width:100%">
      <h3 style="margin-bottom:12px">🔑 Asignar Recurso</h3>
      <div class="form-group">
        <label>ID de Usuario</label>
        <input type="number" name="usuario_id" required placeholder="ID numérico">
      </div>
      <div class="form-group">
        <label>Tipo de Recurso</label>
        <select name="tipo" style="width:100%;padding:10px;border:2px solid var(--border);border-radius:var(--radius)">
          <option value="email">Email Corporativo</option>
          <option value="herramienta">Herramienta</option>
          <option value="suscripcion">Suscripción</option>
          <option value="api_key">API Key</option>
          <option value="acceso_admin">Acceso Admin</option>
        </select>
      </div>
      <div class="form-group">
        <label>Identificador</label>
        <input type="text" name="identificador" placeholder="Ej: usuario@gdlp.org">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Asignar</button>
    </form>
  </div>
  <div class="stat-card">
    <h3 style="margin-bottom:12px">🚪 Registrar Cese de Cargo</h3>
    <p style="font-size:13px;color:var(--text-light);margin-bottom:12px">Inicia el protocolo de offboarding de 48h para revocación de credenciales.</p>
    <div class="form-group">
      <label>ID de Usuario a cesar</label>
      <input type="number" id="cesarUserId" required placeholder="ID numérico" style="width:100%;padding:10px;border:2px solid var(--border);border-radius:var(--radius)">
    </div>
    <button class="btn btn-danger btn-block" onclick="registrarCese()">Registrar Cese</button>
  </div>
  <div class="stat-card">
    <h3 style="margin-bottom:12px">✅ Verificar Revocaciones</h3>
    <p style="font-size:13px;color:var(--text-light);margin-bottom:12px">Comprueba si hay recursos pendientes de revocar cuyo plazo de 48h haya expirado.</p>
    <button class="btn btn-warning btn-block" onclick="verificarRevocaciones()">Ejecutar Verificación</button>
  </div>
</div>

<div class="section">
  <h2>Recursos Asignados</h2>
  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr><th>Usuario</th><th>Tipo</th><th>Identificador</th><th>Estado</th><th>Asignado</th><th>Revocación</th></tr>
      </thead>
      <tbody id="recursosTable">
        <tr><td colspan="6" class="loading-cell">Cargando...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.getElementById('asignarForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = Object.fromEntries(new FormData(form));
    try {
      const result = await apiFetch('/api/recursos/asignar', { method: 'POST', body: JSON.stringify(data) });
      mostrarMensaje('success', result.message);
      form.reset();
    } catch (e) { mostrarMensaje('error', e.message); }
  });

  async function registrarCese() {
    const id = document.getElementById('cesarUserId').value;
    if (!id || !confirm('¿Registrar cese de cargo? Se iniciará el protocolo de revocación de 48h.')) return;
    try {
      const result = await apiFetch(`/api/recursos/cesar/${id}`, { method: 'POST' });
      mostrarMensaje('success', `${result.message}. Recursos afectados: ${result.recursos_afectados}`);
    } catch (e) { mostrarMensaje('error', e.message); }
  }

  async function verificarRevocaciones() {
    try {
      const result = await apiFetch('/api/recursos/verificar-revocaciones', { method: 'POST' });
      mostrarMensaje('success', `${result.revocados.length} recursos revocados. ${result.alertas_incumplimiento} alertas.`);
    } catch (e) { mostrarMensaje('error', e.message); }
  }

  async function cargarRecursos() {
    try {
      const db = await apiFetch('/api/admin/reporte-completo');
    } catch (e) {}
  }

  cargarRecursos();
</script>
</div>
