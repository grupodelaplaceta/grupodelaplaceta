    <div id="alertasContainer" style="display:grid;gap:8px"><p class="loading-cell">Cargando...</p></div>

    <div class="section-header" style="margin-top:24px"><div><h2>🔔 Notificaciones del Sistema</h2></div>
      <button class="btn btn-sm btn-primary" onclick="cargarNotificaciones()">🔄</button>
    </div>
    <div id="notificacionesContainer" style="display:grid;gap:6px"><p class="loading-cell">Cargando...</p></div>
  </div>
