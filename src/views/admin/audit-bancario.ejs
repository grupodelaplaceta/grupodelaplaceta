    <div class="table-container">
      <table class="data-table"><thead><tr><th>ID</th><th>Cuenta</th><th>Tipo</th><th>Motivo</th><th>Estado</th><th>Fecha</th></tr></thead>
        <tbody id="cumplimientoBody"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody>
