<div class="dashboard">
  <div class="dashboard-header">
    <h1>🏛️ Panel de Gobierno — Gestión Bancaria</h1>
    <p class="dashboard-date">Core Bancario y Divisa Placeta (Pz) · Actualizado: <span id="ultimaActualizacion">—</span></p>
  </div>

  <!-- ═══════════ BARRA DE ESTADO EJECUTIVO ═══════════ -->
  <div class="stats-grid" id="resumenGrid">
    <div class="stat-card stat-primary"><div class="stat-icon">👥</div><div class="stat-content"><span class="stat-value" id="totalUsuarios">—</span><span class="stat-label">Ciudadanos</span><span class="stat-detail">Registrados en el core</span></div></div>
    <div class="stat-card stat-success"><div class="stat-icon">🏦</div><div class="stat-content"><span class="stat-value" id="totalCuentas">—</span><span class="stat-label">Cuentas</span><span class="stat-detail">Activas en el sistema</span></div></div>
    <div class="stat-card stat-warning"><div class="stat-icon">💰</div><div class="stat-content"><span class="stat-value" id="masaMonetaria">—</span><span class="stat-label">Masa Monetaria</span><span class="stat-detail">Total Pz circulando</span></div></div>
    <div class="stat-card stat-info"><div class="stat-icon">🏛️</div><div class="stat-content"><span class="stat-value" id="tesoroPz">—</span><span class="stat-label">Tesoro Público</span><span class="stat-detail">Saldo TGLP</span></div></div>
    <div class="stat-card"><div class="stat-icon">📊</div><div class="stat-content"><span class="stat-value" id="txHoy">—</span><span class="stat-label">Tx Hoy</span><span class="stat-detail">Transacciones del día</span></div></div>
    <div class="stat-card stat-danger"><div class="stat-icon">⚠️</div><div class="stat-content"><span class="stat-value" id="totalAlertas">—</span><span class="stat-label">Alertas</span><span class="stat-detail">Pendientes de revisión</span></div></div>
  </div>

  <!-- ═══════════ PESTAÑAS ═══════════ -->
