<div class="dashboard">
  <div class="dashboard-header">
    <h1>Panel de Administración</h1>
    <p class="dashboard-date">Año 2026 · Sistema de Gestión Institucional · CRM v2.0</p>
  </div>

  <!-- KPI Cards -->
  <div class="stats-grid">
    <div class="stat-card stat-primary">
      <div class="stat-icon">👥</div>
      <div class="stat-content">
        <span class="stat-value"><%= totalUsuarios %></span>
        <span class="stat-label">Total Usuarios</span>
        <span class="stat-detail"><span class="status-dot green"></span><%= activos %> activos · <span class="status-dot yellow"></span><%= pendientes %> pendientes</span>
      </div>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-icon">🏦</div>
      <div class="stat-content">
        <span class="stat-value"><%= totalCuentas %></span>
        <span class="stat-label">Cuentas Bancarias</span>
        <span class="stat-detail">💰 <%= (masaMonetaria / 1000).toFixed(1) %>K Pz en circulación</span>
      </div>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-icon">⚖️</div>
      <div class="stat-content">
        <span class="stat-value"><%= expedientesAbiertos %></span>
        <span class="stat-label">Expedientes Abiertos</span>
        <span class="stat-detail"><span class="status-dot red"></span> Pendientes de resolución</span>
      </div>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-icon">📄</div>
      <div class="stat-content">
        <span class="stat-value"><%= docsFirmados || 0 %></span>
        <span class="stat-label">Documentos Firmados</span>
        <span class="stat-detail"><span class="status-dot yellow"></span><%= docsPendientes || 0 %> pendientes</span>
      </div>
    </div>
    <div class="stat-card stat-accent" style="border-left:4px solid #FF6600">
      <div class="stat-icon">🌈</div>
      <div class="stat-content">
        <span class="stat-value"><%= totalJuniors || 0 %></span>
        <span class="stat-label">Placeta Junior</span>
        <span class="stat-detail"><span class="status-dot green"></span><%= juniorsActivos || 0 %> activos</span>
      </div>
    </div>
  </div>

  <!-- Acciones rápidas -->
  <div class="section">
    <div class="section-header">
      <div>
        <h2>Acciones Rápidas</h2>
        <p class="section-desc">Accesos directos a los módulos del sistema</p>
      </div>
    </div>
    <div class="quick-actions">
      <a href="/admin/identidad" class="action-card">
        <span class="action-icon">📋</span>
        <span class="action-title">Altas</span>
        <span class="action-desc">Revisar y aprobar solicitudes de alta</span>
        <span class="action-badge" id="pendientesBadge"><%= pendientes %> pendientes</span>
      </a>
      <a href="/admin/ciudadanos" class="action-card">
        <span class="action-icon">👥</span>
        <span class="action-title">Ciudadanos</span>
        <span class="action-desc">Padrón y gestión de solicitantes</span>
      </a>
      <a href="/admin/bancario" class="action-card">
        <span class="action-icon">🏦</span>
        <span class="action-title">Bancario</span>
        <span class="action-desc">Cuentas, transacciones y estado</span>
      </a>
      <a href="/admin/tributos" class="action-card">
        <span class="action-icon">🧾</span>
        <span class="action-title">Tributos TLP</span>
        <span class="action-desc">IRM, IGF, IVA y declaraciones</span>
      </a>
      <a href="/admin/justicia" class="action-card">
        <span class="action-icon">⚖️</span>
        <span class="action-title">Expedientes</span>
        <span class="action-desc">Casos disciplinarios y resoluciones</span>
        <span class="action-badge"><%= expedientesAbiertos %> abiertos</span>
      </a>
      <a href="/admin/documentos" class="action-card">
        <span class="action-icon">📄</span>
        <span class="action-title">Documentos</span>
        <span class="action-desc">Generar PDF, firmas y gestión documental</span>
      </a>
      <a href="/admin/firmas" class="action-card">
        <span class="action-icon">✍️</span>
        <span class="action-title">Firmas</span>
        <span class="action-desc">Crear y gestionar documentos para firma</span>
        <span class="action-badge"><%= docsPendientes || 0 %> pendientes</span>
      </a>
      <a href="/admin/placeta-junior" class="action-card" style="border-left:4px solid #FF6600">
        <span class="action-icon">🌈</span>
        <span class="action-title">Placeta Junior</span>
        <span class="action-desc">Menores, academia, control parental, documentos</span>
        <span class="action-badge" style="background:#FF6600;color:#fff"><%= juniorsActivos || 0 %> activos</span>
      </a>
      <a href="/admin/rgpd" class="action-card">
        <span class="action-icon">🔒</span>
        <span class="action-title">RGPD</span>
        <span class="action-desc">Solicitudes ARCO y RAT</span>
      </a>
      <a href="/admin/ocio" class="action-card">
        <span class="action-icon">🎲</span>
        <span class="action-title">Ocio</span>
        <span class="action-desc">Loterías y actividades culturales</span>
      </a>
      <a href="/admin/voley-club" class="action-card">
        <span class="action-icon">🏐</span>
        <span class="action-title">Voley Club</span>
        <span class="action-desc">Torneos, partidos y noticias</span>
      </a>
      <a href="/admin/recursos" class="action-card">
        <span class="action-icon">🔧</span>
        <span class="action-title">Recursos</span>
        <span class="action-desc">Recursos digitales y soporte</span>
      </a>

  <!-- ════════ MONITOR / VIGILANCIA (integrado) ════════ -->
  <div class="section">
    <div class="section-header">
      <div>
        <h2>🛡️ Vigilancia y Monitoreo</h2>
        <p class="section-desc">Alertas, logs y actividad del sistema</p>
      </div>
      <div style="display:flex;gap:6px">
        <a href="/admin/audit-bancario" class="btn btn-sm btn-glass">🏛️ Gobierno</a>
        <button class="btn btn-sm btn-outline" onclick="cargarAlertas();cargarLogs()">🔄</button>
      </div>
    </div>

    <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--line)">
      <button class="tab-btn active" onclick="switchTabDash(this,'dashLogs')">📋 Actividad</button>
      <button class="tab-btn" onclick="switchTabDash(this,'dashAlertas')">🚨 Alertas</button>
    </div>

    <!-- Logs -->
    <div id="dashLogs" class="tab-content">
      <div class="table-container">
        <table class="data-table">
          <thead><tr><th>Fecha</th><th>Usuario</th><th>Acción</th><th>Detalle</th></tr></thead>
          <tbody id="logsTable"><tr><td colspan="4" class="loading-cell">Cargando...</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- Alertas -->
    <div id="dashAlertas" class="tab-content" style="display:none">
      <div id="alertasContainerDash" style="display:grid;gap:8px"><p class="loading-cell">Cargando alertas...</p></div>
    </div>
  </div>
</div>

<script>
  function switchTabDash(btn, tabId) {
    document.querySelectorAll('#dashLogs, #dashAlertas').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.section-tabs .tab-btn, [onclick*="switchTabDash"]').forEach(b => {
      b.classList.remove('active');
      b.style.color = 'var(--text-light)';
      b.style.borderBottomColor = 'transparent';
    });
    btn.classList.add('active');
    btn.style.color = 'var(--p500)';
    btn.style.borderBottomColor = 'var(--p500)';
    document.getElementById(tabId).style.display = 'block';
  }

  async function cargarLogs() {
    try {
      const res = await fetch('/api/admin/logs?limite=10');
      const logs = await res.json();
      const tbody = document.getElementById('logsTable');
      tbody.innerHTML = logs.map(log => `
        <tr>
          <td>${new Date(log.creado_en + 'Z').toLocaleString('es-ES')}</td>
          <td>${log.alias || '—'}</td>
          <td><span class="badge badge-${log.accion}">${log.accion}</span></td>
          <td class="cell-truncate">${log.detalle || '—'}</td>
        </tr>
      `).join('');
    } catch (e) {
      document.getElementById('logsTable').innerHTML = '<tr><td colspan="4" class="error-cell">Error al cargar</td></tr>';
    }
  }

  async function cargarAlertas() {
    const container = document.getElementById('alertasContainerDash');
    try {
      const r = await fetch('/api/bancario-proxy/alertas');
      const alertas = await r.json();
      if (!alertas.length) { container.innerHTML = '<p style="color:var(--text-light);text-align:center;padding:20px">✅ Sin alertas activas</p>'; return; }
      container.innerHTML = alertas.map(a => {
        const level = a.level || 'info';
        const icon = level === 'critical' ? '🔴' : level === 'warning' ? '🟡' : level === 'info' ? '🔵' : '⚪';
        return `<div class="card" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:4px solid ${level === 'critical' ? 'var(--red)' : level === 'warning' ? 'var(--warning)' : 'var(--p500)'}">
          <span style="font-size:20px">${icon}</span>
          <div style="flex:1"><strong style="font-size:14px">${a.title || 'Alerta'}</strong>
            <p style="font-size:12.5px;color:var(--text-light);margin:2px 0 0">${a.message || a.detail || ''}</p></div>
          <span style="font-size:11px;color:var(--text-muted);white-space:nowrap">${a.createdAt ? new Date(a.createdAt).toLocaleString('es-ES') : ''}</span>
        </div>`;
      }).join('');
    } catch(e) {
      container.innerHTML = '<p style="color:var(--text-light);text-align:center;padding:20px">📡 Conectando con el core bancario...</p>';
    }
  }

  async function cargarDocumentos() {
    try {
      const res = await fetch('/api/firma/documentos');
      const docs = await res.json();
      document.getElementById('totalDocumentos').textContent = docs.length;
      document.getElementById('docPendientes').textContent = docs.filter(d => d.estado === 'pendiente').length + ' pendientes';
    } catch (e) {}
  }

  cargarLogs();
  cargarAlertas();
  cargarDocumentos();
</script>

<%- include('../parciales/footer') %>
