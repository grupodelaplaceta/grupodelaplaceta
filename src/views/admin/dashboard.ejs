<div class="dashboard">
  <div class="dashboard-header">
    <h1>Panel de Administración</h1>
    <p class="dashboard-date">Año 2026 · Sistema de Gestión Institucional</p>
  </div>

  <!-- Tarjetas de resumen -->
  <div class="stats-grid">
    <div class="stat-card stat-primary">
      <div class="stat-icon">👥</div>
      <div class="stat-content">
        <span class="stat-value"><%= totalUsuarios %></span>
        <span class="stat-label">Total Usuarios</span>
        <span class="stat-detail"><%= activos %> activos · <%= pendientes %> pendientes</span>
      </div>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-icon">🏦</div>
      <div class="stat-content">
        <span class="stat-value"><%= totalCuentas %></span>
        <span class="stat-label">Cuentas Bancarias</span>
        <span class="stat-detail"><%= (masaMonetaria / 1000).toFixed(1) %>K Pz en circulación</span>
      </div>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-icon">⚖️</div>
      <div class="stat-content">
        <span class="stat-value"><%= expedientesAbiertos %></span>
        <span class="stat-label">Expedientes Abiertos</span>
        <span class="stat-detail">Pendientes de resolución</span>
      </div>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-icon">📄</div>
      <div class="stat-content">
        <span class="stat-value" id="totalDocumentos">—</span>
        <span class="stat-label">Documentos</span>
        <span class="stat-detail" id="docPendientes">Cargando...</span>
      </div>
    </div>
  </div>

  <!-- Acciones rápidas -->
  <div class="section">
    <h2>Acciones Rápidas</h2>
    <div class="quick-actions">
      <a href="/admin/identidad" class="action-card">
        <span class="action-icon">📋</span>
        <span class="action-title">Gestionar Altas</span>
        <span class="action-desc">Revisar y aprobar solicitudes pendientes</span>
        <span class="action-badge" id="pendientesBadge"><%= pendientes %> pendientes</span>
      </a>
      <a href="/admin/justicia" class="action-card">
        <span class="action-icon">⚖️</span>
        <span class="action-title">Expedientes</span>
        <span class="action-desc">Gestionar casos disciplinarios</span>
        <span class="action-badge"><%= expedientesAbiertos %> abiertos</span>
      </a>
      <a href="/admin/fiscal" class="action-card">
        <span class="action-icon">💰</span>
        <span class="action-title">Cierre Fiscal</span>
        <span class="action-desc">Ejecutar IRM y monitoreo</span>
      </a>
      <a href="/admin/rgpd" class="action-card">
        <span class="action-icon">🔒</span>
        <span class="action-title">RGPD</span>
        <span class="action-desc">Gestionar solicitudes ARCO y RAT</span>
      </a>
      <a href="/admin/pdf" class="action-card">
        <span class="action-icon">📄</span>
        <span class="action-title">Generar PDF</span>
        <span class="action-desc">Documentos oficiales normativos</span>
      </a>
      <a href="/admin/firmas" class="action-card">
        <span class="action-icon">✍️</span>
        <span class="action-title">Firma Digital</span>
        <span class="action-desc">Documentos pendientes de firma</span>
      </a>
      <a href="/admin/contenidos" class="action-card">
        <span class="action-icon">📝</span>
        <span class="action-title">Contenidos</span>
        <span class="action-desc">Gestionar páginas y avisos</span>
      </a>
      <a href="/admin/voley-club" class="action-card">
        <span class="action-icon">🏐</span>
        <span class="action-title">Voley Club</span>
        <span class="action-desc">Torneos, partidos y noticias</span>
      </a>
    </div>
  </div>

  <!-- Últimos logs -->
  <div class="section">
    <h2>Actividad Reciente</h2>
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Usuario</th>
            <th>Acción</th>
            <th>Detalle</th>
          </tr>
        </thead>
        <tbody id="logsTable">
          <tr><td colspan="4" class="loading-cell">Cargando actividad...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  async function cargarLogs() {
    try {
      const res = await fetch('/api/admin/logs?limite=10');
      const logs = await res.json();
      const tbody = document.getElementById('logsTable');
      tbody.innerHTML = logs.map(log => `
        <tr>
          <td>${new Date(log.creado_en + 'Z').toLocaleString('es-ES')}</td>
          <td>${log.alias || '—'}</td>
          <td><span class="badge badge-${log.accion}">${log.accion}</span></td>
          <td class="cell-truncate">${log.detalle || '—'}</td>
        </tr>
      `).join('');
    } catch (e) {
      document.getElementById('logsTable').innerHTML = '<tr><td colspan="4" class="error-cell">Error al cargar</td></tr>';
    }
  }

  async function cargarDocumentos() {
    try {
      const res = await fetch('/api/firma/documentos');
      const docs = await res.json();
      document.getElementById('totalDocumentos').textContent = docs.length;
      document.getElementById('docPendientes').textContent = docs.filter(d => d.estado === 'pendiente').length + ' pendientes';
    } catch (e) {}
  }

  cargarLogs();
  cargarDocumentos();
</script>

<%- include('../parciales/footer') %>
