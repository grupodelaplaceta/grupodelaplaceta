<div class="dashboard">
  <div class="dashboard-header">
    <h1>🏛️ Panel de Control</h1>
    <p class="dashboard-date">Sistema de Gestión Integral · <%= new Date().toLocaleDateString('es-ES', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %></p>
  </div>

  <!-- Status Bar -->
  <div class="status-bar" id="systemStatusBar">
    <span class="status-item"><span class="dot" id="stSupabase"></span> Supabase</span>
    <span class="status-item"><span class="dot" id="stSQLite"></span> SQLite</span>
    <span class="status-item"><span class="dot" id="stBanco"></span> Banco API</span>
    <span class="status-item"><span class="dot" id="stPlacetaid"></span> PlacetaID</span>
    <span style="flex:1"></span>
    <span style="font-size:10px;color:var(--text-muted)" id="stTimestamp"></span>
  </div>

  <!-- ══ KPIS PRINCIPALES ══ -->
  <div class="dash-grid-4" style="margin-bottom:24px">
    <div class="metric-card">
      <div class="m-icon">👥</div>
      <div class="m-body">
        <div class="m-value" id="dashTotalUsuarios"><%= totalUsuarios %></div>
        <div class="m-label">Ciudadanos</div>
        <div class="m-change up"><span class="status-dot green"></span> <%= activos %> activos · <span class="status-dot yellow"></span> <%= pendientes %> pend.</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="m-icon">🏦</div>
      <div class="m-body">
        <div class="m-value" id="dashTotalCuentas"><%= totalCuentas %></div>
        <div class="m-label">Cuentas Bancarias</div>
        <div class="m-change up">💰 <%= (masaMonetaria / 1000).toFixed(1) %>K Pz en circulación</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="m-icon">🌈</div>
      <div class="m-body">
        <div class="m-value" id="dashTotalJuniors"><%= totalJuniors || 0 %></div>
        <div class="m-label">Placeta Junior</div>
        <div class="m-change up"><span class="status-dot green"></span> <%= juniorsActivos || 0 %> activos</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="m-icon">📄</div>
      <div class="m-body">
        <div class="m-value" id="dashTotalDocs"><%= docsFirmados || 0 %></div>
        <div class="m-label">Documentos</div>
        <div class="m-change"><span class="status-dot yellow"></span> <%= docsPendientes || 0 %> pend. firma</div>
      </div>
    </div>
  </div>

  <!-- ══ MÓDULOS — Acceso Rápido ══ -->
  <div class="section-compact">
    <div class="sc-header">
      <h3>⚡ Acceso Rápido</h3>
      <span style="font-size:12px;color:var(--text-light)"><%= expedientesAbiertos %> expedientes abiertos</span>
    </div>
    <div class="action-grid" style="margin-bottom:24px">
      <a href="/admin/identidad" class="action-item"><span class="ai-icon">📋</span> Altas<span class="ai-badge"><%= pendientes %></span></a>
      <a href="/admin/ciudadanos" class="action-item"><span class="ai-icon">👥</span> Ciudadanos</a>
      <a href="/admin/finanzas" class="action-item"><span class="ai-icon">🏦</span> Finanzas</a>
      <a href="/admin/tributos" class="action-item"><span class="ai-icon">🧾</span> Tributos</a>
      <a href="/admin/justicia" class="action-item"><span class="ai-icon">⚖️</span> Expedientes<span class="ai-badge"><%= expedientesAbiertos %></span></a>
      <a href="/admin/tramitacion" class="action-item"><span class="ai-icon">📋</span> Tramitación</a>
      <a href="/admin/documentos" class="action-item"><span class="ai-icon">📄</span> Documentos</a>
      <a href="/admin/firmas" class="action-item"><span class="ai-icon">✍️</span> Firmas<span class="ai-badge"><%= docsPendientes || 0 %></span></a>
      <a href="/admin/placeta-junior" class="action-item" style="border-left:3px solid #FF6600"><span class="ai-icon">🌈</span> Junior</a>
      <a href="/admin/audit-bancario" class="action-item"><span class="ai-icon">🏛️</span> Gobierno</a>
      <a href="/admin/rgpd" class="action-item"><span class="ai-icon">🔒</span> RGPD</a>
      <a href="/admin/voley-club" class="action-item"><span class="ai-icon">🏐</span> Voley Club</a>
    </div>
  </div>

  <!-- ══ SISTEMA + MONITOREO ══ -->
  <div class="dash-grid-2" style="margin-bottom:18px">
    <div class="glass-card">
      <div class="glass-card-header">
        <h3>🚨 Alertas</h3>
        <button class="btn btn-sm btn-outline" onclick="cargarAlertas()">🔄</button>
      </div>
      <div id="alertasContainerDash" class="empty-state"><div class="empty-icon">📡</div><p>Cargando alertas...</p></div>
    </div>
    <div class="glass-card">
      <div class="glass-card-header">
        <h3>📋 Actividad</h3>
        <button class="btn btn-sm btn-outline" onclick="cargarLogs()">🔄</button>
      </div>
      <div id="logsContainerDash" class="empty-state"><div class="empty-icon">⏳</div><p>Cargando actividad...</p></div>
    </div>
  </div>

  <div class="glass-card" style="margin-bottom:18px">
    <div class="glass-card-header">
      <h3>📊 Sistema</h3>
    </div>
    <div class="dash-grid-4" id="dashSystemStats">
      <div class="stat-mini"><span class="label">🏛️ Tesoro</span><span class="value" id="dashTesoro">—</span></div>
      <div class="stat-mini"><span class="label">💳 Tarjetas</span><span class="value" id="dashTarjetas">—</span></div>
      <div class="stat-mini"><span class="label">⚠️ Cuentas negativas</span><span class="value" id="dashNegativas">—</span></div>
      <div class="stat-mini"><span class="label">📌 Pendientes firma</span><span class="value" id="dashPendientesFirma"><%= docsPendientes || 0 %></span></div>
    </div>
  </div>
</div>

<script>
async function apiFetch(url, opts) {
  const r = await fetch(url, { headers: { 'Content-Type': 'application/json' }, ...opts });
  if (!r.ok) { let msg = 'HTTP ' + r.status; try { const e = await r.json(); if (e.error) msg += ': ' + e.error; } catch {} throw new Error(msg); }
  return r.json();
}

// ── System Status ───────────────────────────────────────────────────────────
async function cargarStatusSistema() {
  try {
    const r = await fetch('/api/admin/status');
    const data = await r.json();
    const map = { online: 'online', error: 'warning', offline: 'offline' };
    const setDot = (id, st) => { const el = document.getElementById(id); if (el) { el.className = 'dot ' + (map[st] || 'offline'); } };
    if (data.status) {
      setDot('stSupabase', data.status.supabase);
      setDot('stSQLite', data.status.sqlite);
      setDot('stBanco', data.status.banco_api);
      setDot('stPlacetaid', data.status.placetid);
    }
    const ts = document.getElementById('stTimestamp');
    if (ts && data.timestamp) ts.textContent = new Date(data.timestamp).toLocaleTimeString('es-ES');
  } catch (e) { /* fallback */ }
}
setTimeout(cargarStatusSistema, 500);
}
async function tryFetch(url) { try { return await apiFetch(url); } catch { return null; } }

async function cargarLogs() {
  const c = document.getElementById('logsContainerDash');
  try {
    const logs = await apiFetch('/api/admin/logs?limite=10');
    if (!logs?.length) { c.innerHTML = '<div class="empty-state"><div class="empty-icon">📭</div><p>Sin actividad reciente</p></div>'; return; }
    c.innerHTML = logs.map(l => `<div class="alert-item info">
      <div class="alert-icon">${l.accion === 'login' ? '🔑' : l.accion === 'logout' ? '🚪' : l.accion === 'generar_pdf' ? '📄' : l.accion === 'aprobar_alta' ? '✅' : l.accion === 'rechazar_alta' ? '❌' : '📌'}</div>
      <div class="alert-body"><div class="alert-title">${l.alias || '—'} <span class="tag tag-purple">${l.accion}</span></div><div class="alert-text">${l.detalle || ''}</div></div>
      <div class="alert-time">${l.creado_en ? new Date(l.creado_en + 'Z').toLocaleString('es-ES') : ''}</div>
    </div>`).join('');
  } catch { c.innerHTML = '<div class="empty-state"><div class="empty-icon">⚠️</div><p>Error al cargar logs</p></div>'; }
}

async function cargarAlertas() {
  const c = document.getElementById('alertasContainerDash');
  try {
    const alertas = await apiFetch('/api/bancario-proxy/alertas');
    if (!alertas?.length) { c.innerHTML = '<div class="empty-state"><div class="empty-icon">✅</div><p>Sin alertas activas</p><div class="sub">Sistema funcionando con normalidad</div></div>'; return; }
    c.innerHTML = alertas.slice(0,8).map(a => {
      const sev = a.severity || a.level || 'info';
      const icon = sev === 'alta' || sev === 'critical' ? '🔴' : sev === 'media' || sev === 'warning' ? '🟡' : '🔵';
      const cls = sev === 'alta' || sev === 'critical' ? 'critical' : sev === 'media' || sev === 'warning' ? 'warning' : 'info';
      return `<div class="alert-item ${cls}">
        <div class="alert-icon">${icon}</div>
        <div class="alert-body"><div class="alert-title">${a.tipo || a.title || 'Alerta'}</div><div class="alert-text">${a.mensaje || a.message || a.detail || ''}</div></div>
        <div class="alert-time">${a.createdAt ? new Date(a.createdAt).toLocaleString('es-ES') : ''}</div>
      </div>`;
    }).join('');
  } catch { c.innerHTML = '<div class="empty-state"><div class="empty-icon">📡</div><p>Conectando con core bancario...</p></div>'; }
}

async function cargarSystemStats() {
  const res = await tryFetch('/api/bancario-proxy/resumen');
  if (res) {
    document.getElementById('dashTesoro').textContent = Number(res.tesoro || 0).toLocaleString('es-ES') + ' Pz';
    document.getElementById('dashNegativas').textContent = res.cuentasNegativas ?? '—';
  }
  const tarjetas = await tryFetch('/api/bancario-proxy/tarjetas');
  if (tarjetas) document.getElementById('dashTarjetas').textContent = (tarjetas.total || 0) + ' (' + (tarjetas.activas || 0) + ' activas)';
}

cargarLogs(); cargarAlertas(); cargarSystemStats();
</script>

<%- include('../parciales/footer') %>
