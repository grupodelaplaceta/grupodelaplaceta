  // ── Load Declarations ─────────────────────────────────────────────────────
  let _todasDeclaraciones = [];

  async function cargarDeclaraciones() {
    try {
      const data = await apiFetch('/api/admin/tributos/declarations');
      _todasDeclaraciones = data;
      aplicarFiltrosYRender();
    } catch (e) {
      document.querySelector('#declaracionesTable tbody').innerHTML = '<tr><td colspan="10" class="error-cell">Error al cargar declaraciones</td></tr>';
    }
  }

  function aplicarFiltrosYRender() {
    const mesFiltro = (document.getElementById('filterMesPeriodo')?.value || '').trim();
    const estadoFiltro = (document.getElementById('filterEstado')?.value || '').trim();
    let filtradas = _todasDeclaraciones;
    if (mesFiltro) filtradas = filtradas.filter(d => d.mes_periodo === mesFiltro);
    if (estadoFiltro) filtradas = filtradas.filter(d => d.estado_pago === estadoFiltro);

    document.getElementById('declTotalCount').textContent = filtradas.length;
    const tbody = document.querySelector('#declaracionesTable tbody');
    if (!filtradas.length) {
      tbody.innerHTML = '<tr><td colspan="10" class="loading-cell">No hay declaraciones' + (mesFiltro || estadoFiltro ? ' con esos filtros' : '') + '.</td></tr>';
      return;
    }
    tbody.innerHTML = filtradas.map(item => {
      const estado = item.estado_pago || 'Borrador';
      const nombreContrib = item.nombre || item.placeta_id || item.contributor_id || '—';
      const totalCuota = (item.cuota_irm || 0) + (item.cuota_igf || 0);
      const estadoBadge = estado === 'Cobrado_Exito' ? 'badge-activo'
        : estado === 'Aprobada' ? 'badge-login'
        : estado === 'Emitido' ? 'badge-primary'
        : estado === 'Pendiente_Aprobacion' ? 'badge-pendiente'
        : estado === 'Borrador' ? 'badge-baja' : 'badge-baja';
      const bypassExplicado = item.bypass_junta_directiva
        ? '<span title="Aprobado sin Junta Directiva (bypass)">✅ Bypass</span>'
        : (item.estado_pago === 'Aprobada' || item.estado_pago === 'Emitido' || item.estado_pago === 'Cobrado_Exito')
          ? '<span title="Aprobado por Junta Directiva">🏛️ JD</span>'
          : '—';

      // Botones según estado
      let acciones = '';
      if (estado === 'Borrador') {
        acciones = `
          <button class="btn btn-sm btn-primary" onclick="publicarDeclaracion('${item.id}')" title="Publicar → Pendiente Aprobación">📤 Publicar</button>
          <button class="btn btn-sm btn-success" onclick="aprobarDeclaracionDirecta('${item.id}')" title="Aprobar directamente (bypass Junta)">⚡ Bypass + Aprobar</button>
          <button class="btn btn-sm btn-danger" onclick="eliminarDeclaracion('${item.id}')" title="Eliminar borrador">🗑️</button>`;
      } else if (estado === 'Pendiente_Aprobacion') {
        acciones = `
          <button class="btn btn-sm btn-success" onclick="aprobarDeclaracion('${item.id}')" title="Aprobar para cobro">✅ Aprobar</button>
          <button class="btn btn-sm btn-outline" onclick="rechazarDeclaracion('${item.id}')" title="Rechazar → vuelve a Borrador">↩️ Rechazar</button>`;
      } else if (estado === 'Aprobada') {
        acciones = `
          <button class="btn btn-sm btn-warning" onclick="emitirDeclaracion('${item.id}')" title="Emitir y cobrar al banco">📨 Emitir + Cobrar</button>`;
      } else if (estado === 'Emitido') {
        acciones = `<span style="font-size:12px;color:var(--text-light)">📨 Emitida (pendiente cobro)</span>`;
      } else if (estado === 'Cobrado_Exito') {
        acciones = `<span style="font-size:12px;color:var(--success)">💰 Cobrada${item.transaction_id_blp ? ' · ID: ' + item.transaction_id_blp.slice(0,10) : ''}</span>`;
      }
      acciones += ` <button class="btn btn-sm btn-glass" onclick="descargarPDFDeclaracion('${item.id}')" title="Descargar PDF">📄</button>`;

      return `<tr>
        <td><input type="checkbox" class="declCheck" value="${item.id}" data-estado="${estado}"></td>
        <td><strong>${nombreContrib}</strong><br><small style="color:var(--text-light)">${item.dip || '—'}</small></td>
        <td><span class="pill pill-purple">${item.mes_periodo || '—'}</span></td>
        <td title="PM: ${formatMoneda(item.patrimonio_medio)}">${formatMoneda(item.cuota_irm)}</td>
        <td>${formatMoneda(item.cuota_igf)}</td>
        <td><strong>${formatMoneda(totalCuota)}</strong></td>
        <td><span class="badge ${estadoBadge}" style="cursor:help" title="${explicarEstado(estado)}">${estado.replace(/_/g,' ')}</span></td>
        <td style="font-size:12px">${bypassExplicado}</td>
        <td>${item.updated_at ? new Date(item.updated_at).toLocaleDateString('es-ES') : '—'}</td>
        <td style="display:flex;gap:4px;flex-wrap:wrap">${acciones}</td>
      </tr>`;
    }).join('');
  }

  function filtrarDeclaraciones() { aplicarFiltrosYRender(); }

  function explicarEstado(e) {
    const map = {
      'Borrador': '📝 Borrador — Sin publicar. Editable',
      'Pendiente_Aprobacion': '⏳ Pendiente de aprobación por la Junta Directiva',
      'Aprobada': '✅ Aprobada por la Junta — Lista para emitir y cobrar',
      'Emitido': '📨 Emitida — Cobro pendiente de procesar',
      'Cobrado_Exito': '💰 Cobrada con éxito — Pago realizado'
    };
    return map[e] || e;
  }

  function toggleSelectAllDecl(checked) {
    document.querySelectorAll('.declCheck').forEach(c => c.checked = checked);
  }

  // ── Acciones individuales ────────────────────────────────────────────────

  // Publicar (Borrador → Pendiente_Aprobacion)
  async function publicarDeclaracion(id) {
    try {
      const bypass = confirm('¿Quieres BYPASS la Junta Directiva?\n\nEl "bypass" permite publicar esta declaración directamente sin esperar la aprobación de la Junta.\n\n• Aceptar = BYPASS (aprobación automática)\n• Cancelar = Pendiente de Junta');
      const res = await apiFetch('/api/admin/tributos/declarations/' + id + '/publish', {
        method: 'PUT',
        body: JSON.stringify({ bypass_junta_directiva: bypass })
      });
      mostrarToast('success', bypass ? '⚡ Publicada con bypass (aprobación automática)' : '📤 Publicada. Pendiente de aprobación de la Junta');
      cargarDeclaraciones();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  // Aprobar (Pendiente_Aprobacion → Aprobada)
  async function aprobarDeclaracion(id) {
    try {
      const res = await apiFetch('/api/admin/tributos/declarations/' + id + '/approve', { method: 'PUT' });
      mostrarToast('success', '✅ Declaración aprobada por la Junta Directiva');
      cargarDeclaraciones();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  // Aprobación directa desde Borrador (bypass)
  async function aprobarDeclaracionDirecta(id) {
    if (!confirm('⚡ BYPASS: ¿Aprobar esta declaración directamente sin pasar por Junta Directiva?\n\nEsto la publicará y aprobará en un solo paso.')) return;
    try {
      const res = await apiFetch('/api/admin/tributos/declarations/' + id + '/publish', {
        method: 'PUT',
        body: JSON.stringify({ bypass_junta_directiva: true })
      });
      if (res.success) {
        await apiFetch('/api/admin/tributos/declarations/' + id + '/approve', { method: 'PUT' });
        mostrarToast('success', '⚡ Bypass completado: declaración publicada y aprobada');
      }
      cargarDeclaraciones();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  // Rechazar (Pendiente_Aprobacion → Borrador)
  async function rechazarDeclaracion(id) {
    if (!confirm('¿Rechazar esta declaración? Volverá a estado Borrador para su revisión.')) return;
    try {
      const res = await apiFetch('/api/admin/tributos/declarations/' + id + '/reject', { method: 'PUT' });
      mostrarToast('warning', '↩️ Declaración devuelta a Borrador');
      cargarDeclaraciones();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  // Emitir + cobrar (Aprobada → Emitida/Cobrado_Exito)
  async function emitirDeclaracion(id) {
    if (!confirm('📨 ¿Emitir esta declaración?\n\n• Se intentará cobrar el importe directamente desde el banco BLP.\n• La cuenta TGLP recibirá los fondos.')) return;
    try {
      mostrarToast('info', '⏳ Procesando emisión y cobro...');
      const res = await apiFetch('/api/admin/tributos/declarations/' + id + '/emit', { method: 'PUT' });
      if (res.transactionId) {
        mostrarToast('success', '💰 Cobro realizado. ID transacción: ' + res.transactionId.slice(0,12));
      } else if (res.paymentError) {
        mostrarToast('warning', '📨 Emitida pero el cobro no se completó: ' + res.paymentError);
      } else {
        mostrarToast('success', '📨 Declaración emitida correctamente');
      }
      cargarDeclaraciones();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  // ── Acciones masivas ─────────────────────────────────────────────────────
  function abrirModalPublicacionMasiva() {
    const mesInput = document.getElementById('bulkMesPeriodo');
    if (mesInput && !mesInput.value) mesInput.value = new Date().toISOString().slice(0, 7);
    document.getElementById('bulkResultado').style.display = 'none';
    abrirModal('modalPublicacionMasiva');
  }

  async function ejecutarBulk(accion) {
    const mes = document.getElementById('bulkMesPeriodo')?.value;
    if (!mes) { mostrarToast('error', 'Selecciona un mes'); return; }

    const accionLabels = { publish: '📤 Publicar', approve: '✅ Aprobar', emit: '📨 Emitir' };
    const confirmMsg = accion === 'publish'
      ? `¿Publicar TODAS las declaraciones de ${mes}?\n\nLas que estén en Borrador pasarán a Pendiente_Aprobacion.`
      : accion === 'approve'
        ? `¿Aprobar TODAS las declaraciones pendientes de ${mes}?\n\nSolo se aprobarán las que estén en estado Pendiente_Aprobacion.`
        : `¿Emitir y cobrar TODAS las declaraciones aprobadas de ${mes}?\n\nSe intentará cobrar cada una desde el banco BLP.`;

    if (!confirm(confirmMsg)) return;

    mostrarToast('info', '⏳ Procesando...');
    try {
      const res = await apiFetch('/api/admin/tributos/declarations/bulk/' + accion, {
        method: 'PUT',
        body: JSON.stringify({ mes_periodo: mes })
      });
      document.getElementById('bulkResultado').style.display = 'block';
      document.getElementById('bulkResultado').innerHTML =
        '<div class="alert alert-success">' +
        '✅ ' + (accionLabels[accion] || accion) + ': ' + res.procesadas + '/' + res.total + ' procesadas' +
        (res.errores > 0 ? ' · ❌ ' + res.errores + ' errores' : '') +
        '</div>';
      mostrarToast('success', '✅ Acción masiva completada: ' + res.procesadas + ' declaraciones');
      cargarDeclaraciones();
    } catch (e) {
      document.getElementById('bulkResultado').style.display = 'block';
      document.getElementById('bulkResultado').innerHTML = '<div class="alert alert-danger">❌ Error: ' + e.message + '</div>';
    }
  }

  // ── Descargar PDF de declaración ──────────────────────────────────────
  async function descargarPDFDeclaracion(id) {
    try {
      const data = await apiFetch('/api/admin/tributos/declarations');
      const item = data.find(d => d.id === id);
      if (!item) { mostrarToast('error', 'Declaración no encontrada'); return; }
      // Abrir en nueva pestaña o descargar
      const res = await fetch('/api/admin/tributos/pdf/declaracion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(item)
      });
      if (!res.ok) { mostrarToast('error', 'Error al generar PDF'); return; }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `TLP-DECLARACION-${item.mes_periodo || id.slice(0,8)}.pdf`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      mostrarToast('success', '✅ PDF descargado');
    } catch (e) {
      mostrarToast('error', 'Error: ' + e.message);
    }
  }

  // ── Eliminar declaración (solo borradores) ────────────────────────────
  async function eliminarDeclaracion(id) {
    if (!confirm('¿Eliminar esta declaración borrador? Esta acción no se puede deshacer.')) return;
    try {
      await apiFetch('/api/admin/tributos/declarations/' + id, { method: 'DELETE' });
      mostrarToast('success', '🗑️ Borrador eliminado');
      cargarDeclaraciones();
    } catch (e) {
      mostrarToast('error', 'Error: ' + e.message);
    }
  }

  // ── Load contributors for reconcile dropdown ──────────────────────────
  async function cargarContribuyentesSelect() {
    try {
      const data = await apiFetch('/api/admin/tributos/contributors');
      const select = document.getElementById('reconcileContribuyente');
      if (!select) return;
      select.innerHTML = '<option value="">Seleccionar contribuyente...</option>';
      data.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.placeta_id;
        opt.textContent = c.placeta_id + ' · ' + c.nombre;
        select.appendChild(opt);
      });
    } catch (e) { /* fallback */ }
  }

  // ── Reconciliation Engine ─────────────────────────────────────────────────
  async function ejecutarReconciliacion() {
    const placetaId = document.getElementById('reconcileContribuyente')?.value;
    const mes = document.getElementById('reconcileMes')?.value;
    if (!placetaId) { mostrarToast('error', 'Selecciona un contribuyente'); return; }
    if (!mes) { mostrarToast('error', 'Selecciona un mes'); return; }

    mostrarToast('info', '⏳ Reconciliando saldos diarios...');
    document.getElementById('reconciliationResults').style.display = 'block';
    document.getElementById('dailyBalancesBody').innerHTML = '<tr><td colspan="5" class="loading-cell"><span class="spinner"></span> Calculando...</td></tr>';

    try {
      const res = await apiFetch('/api/admin/tributos/reconcile/' + encodeURIComponent(placetaId), {
        method: 'POST',
        body: JSON.stringify({ mes: mes })
      });

      if (res.success) {
        mostrarToast('success', '✅ Reconciliación completada: ' + res.dias_con_datos + '/' + res.total_dias + ' días');

        document.getElementById('reconciliationSummary').innerHTML =
          '<div class="stat-card stat-primary"><div class="stat-icon">👤</div><div class="stat-content">' +
            '<span class="stat-value">' + res.nombre + '</span>' +
            '<span class="stat-label">' + res.placeta_id + '</span>' +
          '</div></div>' +
          '<div class="stat-card stat-success"><div class="stat-icon">📅</div><div class="stat-content">' +
            '<span class="stat-value">' + res.dias_con_datos + '/' + res.total_dias + '</span>' +
            '<span class="stat-label">Días Conciliados</span>' +
          '</div></div>' +
          '<div class="stat-card stat-info"><div class="stat-icon">💰</div><div class="stat-content">' +
            '<span class="stat-value">' + formatMoneda(res.patrimonio_medio) + '</span>' +
            '<span class="stat-label">Patrimonio Medio</span>' +
          '</div></div>' +
          '<div class="stat-card ' + (res.dias_con_datos >= res.total_dias ? 'stat-success' : 'stat-warning') + '"><div class="stat-icon">📊</div><div class="stat-content">' +
            '<span class="stat-value">' + formatMoneda(res.saldo_actual) + '</span>' +
            '<span class="stat-label">Saldo Actual (agregado)</span>' +
          '</div></div>';

        // ── Desglose por cuenta bancaria ──
        const cuentas = res.cuentas || [];
        if (cuentas.length > 0) {
          var cuentasHtml = '<div class="section-header" style="margin-top:16px"><div><h3>🏦 Desglose por Cuenta Bancaria</h3></div></div>' +
            '<div class="table-container"><table class="data-table"><thead><tr>' +
            '<th>Cuenta</th><th>Tipo</th><th>Saldo (Pz)</th><th>PlacetaID</th><th>IBAN</th><th>% del Total</th></tr></thead><tbody>';
          var totalSaldo = res.saldo_actual || 0;
          cuentas.forEach(function(c) {
            var pct = totalSaldo > 0 ? ((c.balancePz / totalSaldo) * 100).toFixed(1) : '0.0';
            cuentasHtml += '<tr>' +
              '<td><strong>' + (c.displayName || c.id || '—') + '</strong></td>' +
              '<td><span class="pill pill-' + (c.type === 'Savings' ? 'purple' : c.type === 'Investment' ? 'gold' : 'green') + '">' + (c.type || '—') + '</span></td>' +
              '<td><strong>' + formatMoneda(c.balancePz) + '</strong></td>' +
              '<td>' + (c.placetaId || '—') + '</td>' +
              '<td style="font-size:11px;font-family:monospace">' + (c.iban || '—') + '</td>' +
              '<td>' + pct + '%</td></tr>';
          });
          cuentasHtml += '<tr style="font-weight:700;background:var(--p050)"><td>📊 TOTAL</td><td></td><td>' + formatMoneda(totalSaldo) + '</td><td></td><td></td><td>100%</td></tr>';
          cuentasHtml += '</tbody></table></div>';
          document.getElementById('reconciliationSummary').insertAdjacentHTML('afterend', cuentasHtml);
        }

        const balances = res.balances || [];
        document.getElementById('dailyBalancesBody').innerHTML = balances.map(function(b) {
          var origenClass = b.origen === 'banco' ? 'badge-activo' : 'badge-pendiente';
          var origenLabel = b.origen === 'banco' ? 'Banco' : 'Reconstruido';
          var dia = b.fecha ? parseInt(b.fecha.slice(-2)) : '—';
          return '<tr>' +
            '<td><strong>' + dia + '</strong></td>' +
            '<td>' + (b.fecha || '—') + '</td>' +
            '<td><strong>' + formatMoneda(b.saldo) + '</strong></td>' +
            '<td>' + (b.transactions_count || 0) + '</td>' +
            '<td><span class="badge ' + origenClass + '">' + origenLabel + '</span></td>' +
          '</tr>';
        }).join('');

        cargarDeclaraciones();
        cargarTributosResumen();
      } else {
        mostrarToast('error', res.error || 'Error en reconciliación');
      }
    } catch (err) {
      mostrarToast('error', 'Error al reconciliar: ' + (err.message || err));
      document.getElementById('dailyBalancesBody').innerHTML = '<tr><td colspan="5" class="error-cell">Error al calcular</td></tr>';
    }
  }

  // ── Load reconciliation status ────────────────────────────────────────────
  async function cargarEstadoReconciliacion() {
    const mesInput = document.getElementById('reconcileMes');
    const mes = mesInput?.value || new Date().toISOString().slice(0, 7);
    document.getElementById('reconciliationStatus').style.display = 'block';
    document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="loading-cell"><span class="spinner"></span> Cargando...</td></tr>';

    try {
      const res = await apiFetch('/api/admin/tributos/reconciliation-status?mes=' + mes);
      var list = res.contributors || [];
      if (!list.length) {
        document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="loading-cell">Sin contribuyentes registrados</td></tr>';
        return;
      }
      document.getElementById('reconStatusBody').innerHTML = list.map(function(c) {
        var pct = c.total_dias_mes > 0 ? Math.round(c.dias_conciliados / c.total_dias_mes * 100) : 0;
        var statusClass = pct >= 100 ? 'badge-activo' : pct >= 50 ? 'badge-pendiente' : 'badge-baja';
        var statusLabel = pct >= 100 ? '✅ Completo' : pct >= 50 ? '⏳ Parcial' : '❌ Pendiente';
        return '<tr>' +
          '<td><strong>' + c.placeta_id + '</strong><br><small>' + c.nombre + '</small></td>' +
          '<td><span class="pill ' + (c.tipo_sujeto === 'Empresa' ? 'pill-purple' : 'pill-green') + '">' + (c.tipo_sujeto || '—') + '</span></td>' +
          '<td>' + c.total_dias_mes + '</td>' +
          '<td>' + c.dias_conciliados + '</td>' +
          '<td>' + c.dias_pendientes + '</td>' +
          '<td><strong>' + formatMoneda(c.patrimonio_medio) + '</strong></td>' +
          '<td><span class="badge ' + statusClass + '">' + statusLabel + '</span></td>' +
        '</tr>';
      }).join('');
    } catch (err) {
      document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="error-cell">Error al cargar estado</td></tr>';
    }
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    cargarInhibicion();
    cargarTributosResumen();
    cargarContribuyentes();
    cargarFacturas();
    cargarDeclaraciones();
    cargarContribuyentesSelect();
    const mesInput = document.getElementById('reconcileMes');
    if (mesInput) mesInput.value = new Date().toISOString().slice(0, 7);
    // Inicializar buscadores
    _buscadorAltaPersona = crearBuscador('buscadorAltaPersona', {
      tipo: 'persona', placeholder: '🔍 Buscar por nombre, DIP o PlacetaID...',
      onSelect: (item) => { _altaPersonaSeleccionada = item; }
    });
    _buscadorAltaEmpresa = crearBuscador('buscadorAltaEmpresa', {
      tipo: 'empresa', placeholder: '🔍 Buscar empresa por nombre o EIP...',
      onSelect: (item) => { _altaEmpresaSeleccionada = item; }
    });
  });
</script>
