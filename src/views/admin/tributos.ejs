<div class="dashboard">
  <div class="dashboard-header">
    <h1>🧾 Gestión de Tributos</h1>
    <p class="dashboard-date">Módulo Tributario TLP · Control de contribuyentes, declaraciones e IVA</p>
    <div style="display:flex;gap:8px;margin-top:12px">
      <a href="/admin/bancario" class="btn btn-sm btn-glass">🏦 Bancario</a>
      <a href="/admin/empresas" class="btn btn-sm btn-glass">🏢 Empresas</a>
      <a href="/admin/audit-bancario" class="btn btn-sm btn-glass">🏛️ Gobierno</a>
    </div>
  </div>

  <!-- KPI Cards -->
  <div class="stats-grid">
    <div class="stat-card stat-primary">
      <div class="stat-icon">🧾</div>
      <div class="stat-content">
        <span class="stat-value" id="contribuyentesTotal">—</span>
        <span class="stat-label">Contribuyentes</span>
        <span class="stat-detail">Registros fiscales en el padrón</span>
      </div>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-icon">📌</div>
      <div class="stat-content">
        <span class="stat-value" id="declaracionesTotal">—</span>
        <span class="stat-label">Declaraciones</span>
        <span class="stat-detail">Mensuales y en borrador</span>
      </div>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-icon">💶</div>
      <div class="stat-content">
        <span class="stat-value" id="facturasTotal">—</span>
        <span class="stat-label">Facturas</span>
        <span class="stat-detail">Emitidas en el periodo</span>
      </div>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-icon">📊</div>
      <div class="stat-content">
        <span class="stat-value" id="importeTotal">—</span>
        <span class="stat-label">Importe Total</span>
        <span class="stat-detail" id="ivaTotal">IVA total</span>
      </div>
    </div>
  </div>

  <!-- Inhibición Switch -->
  <div class="section">
    <div class="inhibition-switch">
      <div>
        <div class="switch-label">🔒 Inhibición de Recaudación del Periodo</div>
        <div class="switch-desc" id="inhibitionDesc">Activado → bloquea cobros automáticos el día 5</div>
      </div>
      <label class="toggle-switch">
        <input type="checkbox" id="inhibitionToggle" onchange="toggleInhibicion(this.checked)">
        <span class="slider"></span>
      </label>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="section">
    <div class="section-header">
      <div>
        <h2>Acciones Rápidas</h2>
        <p class="section-desc">Operaciones frecuentes del módulo tributario</p>
      </div>
    </div>
    <div class="quick-actions">
      <a href="#" class="action-card" onclick="cargarTributosResumen(); return false;">
        <span class="action-icon">🔄</span>
        <span class="action-title">Actualizar panel</span>
        <span class="action-desc">Refrescar métricas tributarias</span>
      </a>
      <a href="#" class="action-card" onclick="abrirModal('modalContribuyente'); return false;">
        <span class="action-icon">➕</span>
        <span class="action-title">Nuevo contribuyente</span>
        <span class="action-desc">Dar de alta en el censo fiscal</span>
      </a>
      <a href="#" class="action-card" onclick="abrirModal('modalAltaRapida'); return false;">
        <span class="action-icon">⚡</span>
        <span class="action-title">Alta rápida por DIP</span>
        <span class="action-desc">Buscar en PlacetaID y dar de alta al instante</span>
      </a>
      <a href="#" class="action-card" onclick="abrirModal('modalFactura'); return false;">
        <span class="action-icon">📄</span>
        <span class="action-title">Nueva factura</span>
        <span class="action-desc">Crear factura con IVA del 12%</span>
      </a>
      <a href="#" class="action-card" onclick="abrirModal('modalDeclaracion'); return false;">
        <span class="action-icon">📑</span>
        <span class="action-title">Nueva declaración</span>
        <span class="action-desc">Crear declaración mensual</span>
      </a>
    </div>
  </div>

  <!-- ── Daily Declarations / Reconciliation ───────────────────────────── -->
  <div class="section">
    <div class="section-header">
      <div>
        <h2>📅 Conciliación de Declaraciones Diarias</h2>
        <p class="section-desc">Reconstruye saldos diarios desde transacciones bancarias y calcula patrimonio medio</p>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <select id="reconcileContribuyente" style="width:180px;padding:8px 12px;border:2px solid var(--line);border-radius:var(--radius);font-family:var(--font);font-size:13px">
          <option value="">Seleccionar...</option>
        </select>
        <input type="month" id="reconcileMes" style="width:160px;padding:8px 12px;border:2px solid var(--line);border-radius:var(--radius);font-family:var(--font);font-size:13px">
        <button class="btn btn-primary btn-sm" onclick="ejecutarReconciliacion()">🔄 Reconciliar</button>
        <button class="btn btn-outline btn-sm" onclick="cargarEstadoReconciliacion()">📊 Estado</button>
      </div>
    </div>

    <!-- Resultados de reconciliación -->
    <div id="reconciliationResults" style="display:none">
      <div class="stats-grid" style="margin-bottom:16px" id="reconciliationSummary"></div>
      <div class="table-container">
        <table class="data-table" id="dailyBalancesTable">
          <thead>
            <tr>
              <th>Día</th>
              <th>Fecha</th>
              <th>Saldo (Pz)</th>
              <th>Transacciones</th>
              <th>Origen</th>
            </tr>
          </thead>
          <tbody id="dailyBalancesBody">
            <tr><td colspan="5" class="loading-cell">Selecciona un contribuyente y ejecuta reconciliación</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Estado de reconciliación general -->
    <div id="reconciliationStatus" style="display:none;margin-top:16px">
      <div class="table-container">
        <table class="data-table" id="reconStatusTable">
          <thead>
            <tr>
              <th>Contribuyente</th>
              <th>Tipo</th>
              <th>Días mes</th>
              <th>Conciliados</th>
              <th>Pendientes</th>
              <th>Patrimonio Medio</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody id="reconStatusBody">
            <tr><td colspan="7" class="loading-cell">Cargando estado...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Secciones con tabs -->
  <div class="section">
    <div class="section-header">
      <div>
        <h2>Registros Tributarios</h2>
        <p class="section-desc">Consulta y gestión de datos fiscales</p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <input type="search" data-search="#contribuyentesTable" placeholder="🔍 Buscar contribuyente..." style="width:220px;padding:8px 12px;border:2px solid var(--line);border-radius:var(--radius);font-family:var(--font);font-size:13px">
      </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--line);padding-bottom:0">
      <button class="tab-btn active" data-tab="tabContribuyentes" onclick="switchTab(this,'tabContribuyentes')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--p500);border-bottom:3px solid var(--p500);margin-bottom:-2px;transition:var(--transition)">👥 Contribuyentes</button>
      <button class="tab-btn" data-tab="tabFacturas" onclick="switchTab(this,'tabFacturas')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--text-light);transition:var(--transition)">📄 Facturas</button>
      <button class="tab-btn" data-tab="tabDeclaraciones" onclick="switchTab(this,'tabDeclaraciones')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--text-light);transition:var(--transition)">📑 Declaraciones</button>
    </div>

    <!-- Contribuyentes -->
    <div id="tabContribuyentes" class="tab-content">
      <div class="table-container">
        <table class="data-table" id="contribuyentesTable">
          <thead>
            <tr>
              <th>Placeta ID</th>
              <th>Nombre</th>
              <th>DIP</th>
              <th>Tipo</th>
              <th>Estado fiscal</th>
              <th>Roles</th>
              <th>Alta</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="7" class="loading-cell">Cargando contribuyentes...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Facturas -->
    <div id="tabFacturas" class="tab-content" style="display:none">
      <div class="table-container">
        <table class="data-table" id="facturasTable">
          <thead>
            <tr>
              <th>Factura</th>
              <th>Emisor</th>
              <th>Receptor</th>
              <th>Base</th>
              <th>IVA</th>
              <th>Total</th>
              <th>CSV</th>
              <th>Fecha</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="9" class="loading-cell">Cargando facturas...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Declaraciones -->
    <div id="tabDeclaraciones" class="tab-content" style="display:none">
      <div class="table-container">
        <table class="data-table" id="declaracionesTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Placeta ID</th>
              <th>Periodo</th>
              <th>Cuota IRM</th>
              <th>Cuota IGF</th>
              <th>Estado</th>
              <th>Bypass</th>
              <th>Fecha</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="9" class="loading-cell">Cargando declaraciones...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- ── Modal: Alta Rápida por DIP ──────────────────────────────────────────── -->
<div class="modal-overlay" id="modalAltaRapida">
  <div class="modal-window">
    <div class="modal-header">
      <h3>⚡ Alta Rápida</h3>
      <button class="modal-close" data-modal-close>✕</button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom:16px;display:flex;gap:8px">
        <button class="btn btn-sm btn-primary" id="btnAltaPersona" onclick="selectAltaTipo('persona')" style="flex:1">👤 Persona Física</button>
        <button class="btn btn-sm btn-outline" id="btnAltaEmpresa" onclick="selectAltaTipo('empresa')" style="flex:1">🏢 Empresa</button>
      </div>
      <form id="formAltaRapida" class="form-grid" style="box-shadow:none;padding:0;border:none;background:none">
        <div id="altaRapidaPersonaFields">
          <label>👤 Persona</label>
          <div id="buscadorAltaPersona"></div>
        </div>
        <div id="altaRapidaEmpresaFields" style="display:none">
          <label>🏢 Empresa</label>
          <div id="buscadorAltaEmpresa"></div>
        </div>
        <div style="grid-column:1/-1;display:flex;gap:12px;justify-content:flex-end;margin-top:8px">
          <button type="button" class="btn btn-outline" data-modal-close>Cancelar</button>
          <button class="btn btn-primary" type="submit">Buscar y dar de alta</button>
        </div>
      </form>
      <div id="altaRapidaResultado" style="margin-top:16px;display:none"></div>
    </div>
  </div>
</div>

<script>
  let _buscadorAltaPersona, _buscadorAltaEmpresa;

  function selectAltaTipo(tipo) {
    document.getElementById('btnAltaPersona').className = tipo === 'persona' ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-outline';
    document.getElementById('btnAltaEmpresa').className = tipo === 'empresa' ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-outline';
    document.getElementById('altaRapidaPersonaFields').style.display = tipo === 'persona' ? 'block' : 'none';
    document.getElementById('altaRapidaEmpresaFields').style.display = tipo === 'empresa' ? 'block' : 'none';
    window._altaTipo = tipo;
  }
  selectAltaTipo('persona');

  document.getElementById('formAltaRapida')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const tipo = window._altaTipo || 'persona';
    const selPersona = _buscadorAltaPersona?.getSelected();
    const selEmpresa = _buscadorAltaEmpresa?.getSelected();
    const resultado = document.getElementById('altaRapidaResultado');
    resultado.style.display = 'block';

    if (tipo === 'persona') {
      if (!selPersona) { resultado.innerHTML = '<div class="alert alert-error">❌ Selecciona una persona del buscador</div>'; return; }
      resultado.innerHTML = '<span class="spinner"></span> Buscando y registrando...';
      try {
        const res = await apiFetch('/api/admin/tributos/contributors/alta-rapida', {
          method: 'POST', body: JSON.stringify({ dip: selPersona.dip, tipo_sujeto: 'Fisico' })
        });
        if (res.success) {
          resultado.innerHTML = '<div class="alert alert-success">✅ ' + (selPersona.displayName || selPersona.nombre || '') + ' dado de alta</div>';
          cargarContribuyentes(); cargarTributosResumen();
          _buscadorAltaPersona.clear();
        } else resultado.innerHTML = '<div class="alert alert-error">❌ ' + (res.error || 'Error') + '</div>';
      } catch (err) { resultado.innerHTML = '<div class="alert alert-error">❌ ' + (err.message || err) + '</div>'; }
    } else {
      if (!selEmpresa) { resultado.innerHTML = '<div class="alert alert-error">❌ Selecciona una empresa del buscador</div>'; return; }
      resultado.innerHTML = '<span class="spinner"></span> Buscando y registrando...';
      try {
        const res = await apiFetch('/api/admin/tributos/contributors/alta-rapida', {
          method: 'POST', body: JSON.stringify({ eip: selEmpresa.eip, tipo_sujeto: 'Empresa' })
        });
        if (res.success) {
          resultado.innerHTML = '<div class="alert alert-success">✅ ' + (selEmpresa.nombre || 'Empresa') + ' dado de alta</div>';
          cargarContribuyentes(); cargarTributosResumen();
          _buscadorAltaEmpresa.clear();
        } else resultado.innerHTML = '<div class="alert alert-error">❌ ' + (res.error || 'Error') + '</div>';
      } catch (err) { resultado.innerHTML = '<div class="alert alert-error">❌ ' + (err.message || err) + '</div>'; }
    }
  });
    }
  });
</script>

<!-- ── Modal: Nuevo Contribuyente ──────────────────────────────────────────── -->
