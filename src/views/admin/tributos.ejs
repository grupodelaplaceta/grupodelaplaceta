<!-- ── Modal: Nueva Declaración ────────────────────────────────────────────── -->
<div class="modal-overlay" id="modalDeclaracion">
  <div class="modal-window">
    <div class="modal-header">
      <h3>📑 Nueva Declaración</h3>
      <button class="modal-close" data-modal-close>✕</button>
    </div>
    <div class="modal-body">
      <form data-api-form="/api/admin/tributos/declarations" class="form-grid" style="box-shadow:none;padding:0;border:none;background:none">
        <label>Placeta ID <input type="text" name="placeta_id" required placeholder="PID-MKL"></label>
        <label>Periodo (YYYY-MM) <input type="text" name="mes_periodo" required placeholder="2026-07"></label>
        <label>Cuenta BLP <input type="text" name="cuenta_id_blp" placeholder="GDLP-..."></label>
        <label>Patrimonio Medio <input type="number" step="0.01" name="patrimonio_medio" value="0"></label>
        <label>Índice Acumulación <input type="number" step="0.0001" name="indice_acumulacion" value="0"></label>
        <label>Cuota IRM <input type="number" step="0.01" name="cuota_irm" value="0"></label>
        <label>Cuota IGF <input type="number" step="0.01" name="cuota_igf" value="0"></label>
        <div style="grid-column:1/-1;display:flex;gap:12px;justify-content:flex-end;margin-top:8px">
          <button type="button" class="btn btn-outline" data-modal-close>Cancelar</button>
          <button class="btn btn-primary" type="submit">Crear declaración</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // ── Helper: apiFetch para todas las llamadas API ───────────────────────────
  async function apiFetch(url, opts = {}) {
    const r = await fetch(url, {
      headers: { 'Content-Type': 'application/json', ...opts.headers },
      ...opts
    });
    if (!r.ok) { let m = 'HTTP ' + r.status; try { const e = await r.json(); if (e.error) m += ': ' + e.error; } catch {} throw new Error(m); }
    return r.json();
  }

  // ── Tab switching ──────────────────────────────────────────────────────────
  function switchTab(btn, tabId) {
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.style.color = 'var(--text-light)';
      b.style.borderBottom = '3px solid transparent';
      b.style.marginBottom = '-2px';
    });
    btn.style.color = 'var(--p500)';
    btn.style.borderBottom = '3px solid var(--p500)';

    document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
    document.getElementById(tabId).style.display = 'block';
  }

  // ── Inhibition Toggle ──────────────────────────────────────────────────────
  async function toggleInhibicion(checked) {
    try {
      const res = await apiFetch('/api/admin/tributos/inhibition', {
        method: 'PUT',
        body: JSON.stringify({ estado_inhibicion_global: checked })
      });
      if (res.success) {
        document.getElementById('inhibitionDesc').textContent = checked
          ? '🟢 Activado → bloquea cobros automáticos el día 5'
          : '🔴 Desactivado → autoriza compensación automática del BLP';
        mostrarToast('success', checked ? '🔒 Inhibición activada' : '🔓 Inhibición desactivada');
      }
    } catch (e) {
      mostrarToast('error', 'Error al cambiar estado de inhibición');
      document.getElementById('inhibitionToggle').checked = !checked;
    }
  }

  // ── Load inhibition state ─────────────────────────────────────────────────
  async function cargarInhibicion() {
    try {
      const res = await apiFetch('/api/admin/tributos/inhibition');
      const inhibido = res.estado_inhibicion_global !== false;
      document.getElementById('inhibitionToggle').checked = inhibido;
      document.getElementById('inhibitionDesc').textContent = inhibido
        ? '🟢 Activado → bloquea cobros automáticos el día 5'
        : '🔴 Desactivado → autoriza compensación automática del BLP';
    } catch (e) { /* fallback */ }
  }

  // ── Load Summary ──────────────────────────────────────────────────────────
  async function cargarTributosResumen() {
    try {
      const res = await apiFetch('/api/admin/tributos/summary');
      document.getElementById('contribuyentesTotal').textContent = res.contribuyentes;
      document.getElementById('declaracionesTotal').textContent = res.declaraciones;
      document.getElementById('facturasTotal').textContent = res.facturas;
      document.getElementById('importeTotal').textContent = formatMoneda(res.importe_total);
      document.getElementById('ivaTotal').textContent = 'IVA total: ' + formatMoneda(res.iva_total);
    } catch (e) { console.error('[Tributos] Error resumen:', e); }
  }

  // ── Load Contributors ─────────────────────────────────────────────────────
  async function cargarContribuyentes() {
    try {
      const data = await apiFetch('/api/admin/tributos/contributors');
      const tbody = document.querySelector('#contribuyentesTable tbody');
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="7" class="loading-cell">No hay contribuyentes registrados.</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(item => {
        const roles = Array.isArray(item.roles_json) ? item.roles_json.join(', ') : (item.roles_json || '—');
        const estado = item.estado_fiscal || '—';
        const estadoBadge = estado === 'Al Dia' ? 'badge-activo' : estado === 'Moroso' ? 'badge-suspendido' : 'badge-pendiente';
        return `<tr>
          <td><strong>${item.placeta_id}</strong></td>
          <td>${item.nombre}</td>
          <td>${item.dip || '—'}</td>
          <td><span class="pill ${item.tipo_sujeto === 'Empresa' ? 'pill-purple' : 'pill-green'}">${item.tipo_sujeto || '—'}</span></td>
          <td><span class="badge ${estadoBadge}">${estado}</span></td>
          <td style="font-size:12px">${roles}</td>
          <td>${item.fecha_alta_tributos ? new Date(item.fecha_alta_tributos).toLocaleDateString('es-ES') : '—'}</td>
        </tr>`;
      }).join('');
    } catch (e) {
      document.querySelector('#contribuyentesTable tbody').innerHTML = '<tr><td colspan="7" class="error-cell">Error al cargar contribuyentes</td></tr>';
    }
  }

  // ── Load Invoices ─────────────────────────────────────────────────────────
  async function cargarFacturas() {
    try {
      const data = await apiFetch('/api/admin/tributos/invoices?limit=10');
      const tbody = document.querySelector('#facturasTable tbody');
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="9" class="loading-cell">No hay facturas registradas.</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(item => {
        const csv = item.csv_verificacion || '—';
        return `<tr>
          <td><strong>${item.numero_factura}</strong></td>
          <td>${item.emisor_placeta_id}</td>
          <td>${item.receptor_placeta_id}</td>
          <td>${formatMoneda(item.base_imponible)}</td>
          <td>${formatMoneda(item.total_iva)}</td>
          <td><strong>${formatMoneda(item.total_factura)}</strong></td>
          <td style="font-size:11px;font-family:monospace">${csv.length > 12 ? csv.slice(0,12)+'…' : csv}</td>
          <td>${item.fecha_emision ? new Date(item.fecha_emision).toLocaleDateString('es-ES') : '—'}</td>
          <td><button class="btn btn-sm btn-glass" onclick="mostrarToast('info','PDF: ${item.numero_factura}')" title="Descargar PDF">📄</button></td>
        </tr>`;
      }).join('');
    } catch (e) {
      document.querySelector('#facturasTable tbody').innerHTML = '<tr><td colspan="9" class="error-cell">Error al cargar facturas</td></tr>';
    }
  }

  // ── Load Declarations ─────────────────────────────────────────────────────
  async function cargarDeclaraciones() {
    try {
      const data = await apiFetch('/api/admin/tributos/declarations');
      const tbody = document.querySelector('#declaracionesTable tbody');
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="10" class="loading-cell">No hay declaraciones registradas.</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(item => {
        const estado = item.estado_pago || '—';
        const estadoBadge = estado === 'Cobrado_Exito' ? 'badge-activo' : estado === 'Borrador' ? 'badge-pendiente' : estado === 'Emitido' ? 'badge-login' : 'badge-baja';
        const esBorrador = estado === 'Borrador' || !estado;
        return `<tr>
          <td style="font-size:11px;font-family:monospace">${(item.id || '').slice(0,8)}</td>
          <td>${item.placeta_id || item.contributor_id || '—'}</td>
          <td><span class="pill pill-purple">${item.mes_periodo || '—'}</span></td>
          <td title="PM: ${formatMoneda(item.patrimonio_medio)}">${formatMoneda(item.cuota_irm)}</td>
          <td>${formatMoneda(item.cuota_igf)}</td>
          <td><span class="badge ${estadoBadge}">${estado}</span></td>
          <td>${item.bypass_junta_directiva ? '✅ Sí' : '—'}</td>
          <td>${item.updated_at ? new Date(item.updated_at).toLocaleDateString('es-ES') : '—'}</td>
          <td><button class="btn btn-sm btn-glass" onclick="descargarPDFDeclaracion('${item.id}')" title="Descargar PDF">📄</button></td>
          <td>${esBorrador ? `<button class="btn btn-sm btn-danger" onclick="eliminarDeclaracion('${item.id}')" title="Eliminar borrador">🗑️</button>` : ''}</td>
        </tr>`;
      }).join('');
    } catch (e) {
      document.querySelector('#declaracionesTable tbody').innerHTML = '<tr><td colspan="10" class="error-cell">Error al cargar declaraciones</td></tr>';
    }
  }

  // ── Descargar PDF de declaración ──────────────────────────────────────
  async function descargarPDFDeclaracion(id) {
    try {
      const data = await apiFetch('/api/admin/tributos/declarations');
      const item = data.find(d => d.id === id);
      if (!item) { mostrarToast('error', 'Declaración no encontrada'); return; }
      // Abrir en nueva pestaña o descargar
      const res = await fetch('/api/admin/tributos/pdf/declaracion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(item)
      });
      if (!res.ok) { mostrarToast('error', 'Error al generar PDF'); return; }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `TLP-DECLARACION-${item.mes_periodo || id.slice(0,8)}.pdf`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      mostrarToast('success', '✅ PDF descargado');
    } catch (e) {
      mostrarToast('error', 'Error: ' + e.message);
    }
  }

  // ── Eliminar declaración (solo borradores) ────────────────────────────
  async function eliminarDeclaracion(id) {
    if (!confirm('¿Eliminar esta declaración borrador? Esta acción no se puede deshacer.')) return;
    try {
      await apiFetch('/api/admin/tributos/declarations/' + id, { method: 'DELETE' });
      mostrarToast('success', '🗑️ Borrador eliminado');
      cargarDeclaraciones();
    } catch (e) {
      mostrarToast('error', 'Error: ' + e.message);
    }
  }

  // ── Load contributors for reconcile dropdown ──────────────────────────
  async function cargarContribuyentesSelect() {
    try {
      const data = await apiFetch('/api/admin/tributos/contributors');
      const select = document.getElementById('reconcileContribuyente');
      if (!select) return;
      select.innerHTML = '<option value="">Seleccionar contribuyente...</option>';
      data.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.placeta_id;
        opt.textContent = c.placeta_id + ' · ' + c.nombre;
        select.appendChild(opt);
      });
    } catch (e) { /* fallback */ }
  }

  // ── Reconciliation Engine ─────────────────────────────────────────────────
  async function ejecutarReconciliacion() {
    const placetaId = document.getElementById('reconcileContribuyente')?.value;
    const mes = document.getElementById('reconcileMes')?.value;
    if (!placetaId) { mostrarToast('error', 'Selecciona un contribuyente'); return; }
    if (!mes) { mostrarToast('error', 'Selecciona un mes'); return; }

    mostrarToast('info', '⏳ Reconciliando saldos diarios...');
    document.getElementById('reconciliationResults').style.display = 'block';
    document.getElementById('dailyBalancesBody').innerHTML = '<tr><td colspan="5" class="loading-cell"><span class="spinner"></span> Calculando...</td></tr>';

    try {
      const res = await apiFetch('/api/admin/tributos/reconcile/' + encodeURIComponent(placetaId), {
        method: 'POST',
        body: JSON.stringify({ mes: mes })
      });

      if (res.success) {
        mostrarToast('success', '✅ Reconciliación completada: ' + res.dias_con_datos + '/' + res.total_dias + ' días');

        document.getElementById('reconciliationSummary').innerHTML =
          '<div class="stat-card stat-primary"><div class="stat-icon">👤</div><div class="stat-content">' +
            '<span class="stat-value">' + res.nombre + '</span>' +
            '<span class="stat-label">' + res.placeta_id + '</span>' +
          '</div></div>' +
          '<div class="stat-card stat-success"><div class="stat-icon">📅</div><div class="stat-content">' +
            '<span class="stat-value">' + res.dias_con_datos + '/' + res.total_dias + '</span>' +
            '<span class="stat-label">Días Conciliados</span>' +
          '</div></div>' +
          '<div class="stat-card stat-info"><div class="stat-icon">💰</div><div class="stat-content">' +
            '<span class="stat-value">' + formatMoneda(res.patrimonio_medio) + '</span>' +
            '<span class="stat-label">Patrimonio Medio</span>' +
          '</div></div>' +
          '<div class="stat-card ' + (res.dias_con_datos >= res.total_dias ? 'stat-success' : 'stat-warning') + '"><div class="stat-icon">📊</div><div class="stat-content">' +
            '<span class="stat-value">' + formatMoneda(res.saldo_actual) + '</span>' +
            '<span class="stat-label">Saldo Actual</span>' +
          '</div></div>';

        const balances = res.balances || [];
        document.getElementById('dailyBalancesBody').innerHTML = balances.map(function(b) {
          var origenClass = b.origen === 'banco' ? 'badge-activo' : 'badge-pendiente';
          var origenLabel = b.origen === 'banco' ? 'Banco' : 'Reconstruido';
          var dia = b.fecha ? parseInt(b.fecha.slice(-2)) : '—';
          return '<tr>' +
            '<td><strong>' + dia + '</strong></td>' +
            '<td>' + (b.fecha || '—') + '</td>' +
            '<td><strong>' + formatMoneda(b.saldo) + '</strong></td>' +
            '<td>' + (b.transactions_count || 0) + '</td>' +
            '<td><span class="badge ' + origenClass + '">' + origenLabel + '</span></td>' +
          '</tr>';
        }).join('');

        cargarDeclaraciones();
        cargarTributosResumen();
      } else {
        mostrarToast('error', res.error || 'Error en reconciliación');
      }
    } catch (err) {
      mostrarToast('error', 'Error al reconciliar: ' + (err.message || err));
      document.getElementById('dailyBalancesBody').innerHTML = '<tr><td colspan="5" class="error-cell">Error al calcular</td></tr>';
    }
  }

  // ── Load reconciliation status ────────────────────────────────────────────
  async function cargarEstadoReconciliacion() {
    const mesInput = document.getElementById('reconcileMes');
    const mes = mesInput?.value || new Date().toISOString().slice(0, 7);
    document.getElementById('reconciliationStatus').style.display = 'block';
    document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="loading-cell"><span class="spinner"></span> Cargando...</td></tr>';

    try {
      const res = await apiFetch('/api/admin/tributos/reconciliation-status?mes=' + mes);
      var list = res.contributors || [];
      if (!list.length) {
        document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="loading-cell">Sin contribuyentes registrados</td></tr>';
        return;
      }
      document.getElementById('reconStatusBody').innerHTML = list.map(function(c) {
        var pct = c.total_dias_mes > 0 ? Math.round(c.dias_conciliados / c.total_dias_mes * 100) : 0;
        var statusClass = pct >= 100 ? 'badge-activo' : pct >= 50 ? 'badge-pendiente' : 'badge-baja';
        var statusLabel = pct >= 100 ? '✅ Completo' : pct >= 50 ? '⏳ Parcial' : '❌ Pendiente';
        return '<tr>' +
          '<td><strong>' + c.placeta_id + '</strong><br><small>' + c.nombre + '</small></td>' +
          '<td><span class="pill ' + (c.tipo_sujeto === 'Empresa' ? 'pill-purple' : 'pill-green') + '">' + (c.tipo_sujeto || '—') + '</span></td>' +
          '<td>' + c.total_dias_mes + '</td>' +
          '<td>' + c.dias_conciliados + '</td>' +
          '<td>' + c.dias_pendientes + '</td>' +
          '<td><strong>' + formatMoneda(c.patrimonio_medio) + '</strong></td>' +
          '<td><span class="badge ' + statusClass + '">' + statusLabel + '</span></td>' +
        '</tr>';
      }).join('');
    } catch (err) {
      document.getElementById('reconStatusBody').innerHTML = '<tr><td colspan="7" class="error-cell">Error al cargar estado</td></tr>';
    }
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    cargarInhibicion();
    cargarTributosResumen();
    cargarContribuyentes();
    cargarFacturas();
    cargarDeclaraciones();
    cargarContribuyentesSelect();
    const mesInput = document.getElementById('reconcileMes');
    if (mesInput) mesInput.value = new Date().toISOString().slice(0, 7);
    // Inicializar buscadores
    _buscadorAltaPersona = crearBuscador('buscadorAltaPersona', {
      tipo: 'persona', placeholder: '🔍 Buscar por nombre, DIP o PlacetaID...'
    });
    _buscadorAltaEmpresa = crearBuscador('buscadorAltaEmpresa', {
      tipo: 'empresa', placeholder: '🔍 Buscar empresa por nombre o EIP...'
    });
  });
</script>

</script>
