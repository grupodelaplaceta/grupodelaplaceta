<!-- ── Modal: Publicación Masiva ──────────────────────────────────────────── -->
<div class="modal-overlay" id="modalPublicacionMasiva">
  <div class="modal-window" style="max-width:550px">
    <div class="modal-header">
      <h3>📦 Acción Masiva sobre Declaraciones</h3>
      <button class="modal-close" data-modal-close>✕</button>
    </div>
    <div class="modal-body">
      <p style="margin:0 0 12px 0;font-size:14px;color:var(--text-light)">Selecciona el mes y la acción a aplicar a <strong>TODAS</strong> las declaraciones de ese mes.</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
        <label style="flex:1">📅 Mes <input type="month" id="bulkMesPeriodo" style="width:100%"></label>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-sm btn-primary" onclick="ejecutarBulk('publish')" style="flex:1">📤 Publicar todas</button>
        <button class="btn btn-sm btn-success" onclick="ejecutarBulk('approve')" style="flex:1">✅ Aprobar todas</button>
        <button class="btn btn-sm btn-warning" onclick="ejecutarBulk('emit')" style="flex:1">📨 Emitir + cobrar</button>
      </div>
      <div id="bulkResultado" style="margin-top:16px;display:none"></div>
    </div>
  </div>
</div>

<script>
  // ── Helper: apiFetch para todas las llamadas API ───────────────────────────
  async function apiFetch(url, opts = {}) {
    const r = await fetch(url, {
      headers: { 'Content-Type': 'application/json', ...opts.headers },
      ...opts
    });
    if (!r.ok) { let m = 'HTTP ' + r.status; try { const e = await r.json(); if (e.error) m += ': ' + e.error; } catch {} throw new Error(m); }
    return r.json();
  }

  // ── Tab switching ──────────────────────────────────────────────────────────
  function switchTab(btn, tabId) {
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.style.color = 'var(--text-light)';
      b.style.borderBottom = '3px solid transparent';
      b.style.marginBottom = '-2px';
    });
    btn.style.color = 'var(--p500)';
    btn.style.borderBottom = '3px solid var(--p500)';

    document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
    document.getElementById(tabId).style.display = 'block';
  }

