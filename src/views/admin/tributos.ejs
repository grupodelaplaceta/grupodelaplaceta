  // ── Load Contributors ─────────────────────────────────────────────────────
  async function cargarContribuyentes() {
    try {
      const data = await apiFetch('/api/admin/tributos/contributors');
      const tbody = document.querySelector('#contribuyentesTable tbody');
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="9" class="loading-cell">No hay contribuyentes registrados.</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(item => {
        const roles = Array.isArray(item.roles_json) ? item.roles_json.join(', ') : (item.roles_json || '—');
        const estado = item.estado_fiscal || '—';
        const estadoBadge = estado === 'Al Dia' ? 'badge-activo' : estado === 'Moroso' ? 'badge-suspendido' : 'badge-pendiente';
        const tc = item.tipo_contribucion || '—';
        const tcLabel = tc === 'estandar' ? '📊 Estándar' : tc === 'empresa' ? '🏢 Empresa' : tc === 'exenta_junior' ? '🌈 Junior' : tc === 'empresa_exenta_igf' ? '📄 Exenta IGF' : '—';
        return `<tr>
          <td><strong>${item.placeta_id}</strong></td>
          <td>${item.nombre}</td>
          <td>${item.dip || '—'}</td>
          <td><span class="pill ${item.tipo_sujeto === 'Empresa' ? 'pill-purple' : 'pill-green'}">${item.tipo_sujeto || '—'}</span></td>
          <td><span class="badge ${estadoBadge}">${estado}</span></td>
          <td><span class="tag ${tc === 'exenta_junior' ? 'tag-gold' : tc === 'empresa' ? 'tag-purple' : tc === 'empresa_exenta_igf' ? 'tag-blue' : 'tag-green'}">${tcLabel}</span></td>
          <td style="font-size:12px">${roles}</td>
          <td>${item.fecha_alta_tributos ? new Date(item.fecha_alta_tributos).toLocaleDateString('es-ES') : '—'}</td>
          <td><button class="btn btn-sm btn-glass" onclick="editarContribucion('${item.placeta_id}','${item.nombre}','${item.tipo_contribucion||''}')" title="Tipo contribución">⚙️</button></td>
        </tr>`;
      }).join('');
