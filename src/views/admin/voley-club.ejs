<div class="dashboard">
  <div class="dashboard-header">
    <h1>🏐 Voley Club La Placeta</h1>
    <p class="dashboard-date">Gestión directa de torneos, partidos, noticias, socios y solicitudes</p>
  </div>

  <div class="stats-grid" id="vcStats">
    <div class="stat-card stat-primary"><div class="stat-icon">🏆</div><div class="stat-content"><span class="stat-value" id="statTorneos">—</span><span class="stat-label">Torneos</span></div></div>
    <div class="stat-card stat-warning"><div class="stat-icon">⏳</div><div class="stat-content"><span class="stat-value" id="statPartidos">—</span><span class="stat-label">Partidos pend.</span></div></div>
    <div class="stat-card stat-info"><div class="stat-icon">📰</div><div class="stat-content"><span class="stat-value" id="statNoticias">—</span><span class="stat-label">Noticias</span></div></div>
    <div class="stat-card stat-success"><div class="stat-icon">👥</div><div class="stat-content"><span class="stat-value" id="statSocios">—</span><span class="stat-label">Socios</span></div></div>
    <div class="stat-card stat-danger"><div class="stat-icon">📋</div><div class="stat-content"><span class="stat-value" id="statSolicitudes">—</span><span class="stat-label">Solicitudes</span></div></div>
  </div>

  <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--line);flex-wrap:wrap">
    <button class="tab-btn active" onclick="switchVC(this,'tabTorneos')" style="padding:10px 20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--p500);border-bottom:3px solid var(--p500)">🏆 Torneos</button>
    <button class="tab-btn" onclick="switchVC(this,'tabPartidos')" style="padding:10px 20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--text-light)">🏐 Partidos</button>
    <button class="tab-btn" onclick="switchVC(this,'tabNoticias')" style="padding:10px 20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--text-light)">📰 Noticias</button>
    <button class="tab-btn" onclick="switchVC(this,'tabSocios')" style="padding:10px 20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--text-light)">👥 Socios</button>
    <button class="tab-btn" onclick="switchVC(this,'tabSolicitudes')" style="padding:10px 20px;border:none;background:none;font-weight:600;cursor:pointer;color:var(--text-light)">📋 Solicitudes</button>
  </div>

  <!-- TORNEOS -->
  <div id="tabTorneos" class="tab-content">
    <div class="section-header"><div><h2>🏆 Torneos</h2></div><button class="btn btn-sm btn-primary" onclick="crearTorneo()">➕ Nuevo</button></div>
    <div class="table-container"><table class="data-table"><thead><tr><th>Nombre</th><th>Descripción</th><th>Inicio</th><th>Fin</th><th>Estado</th><th>Acción</th></tr></thead>
      <tbody id="torneosBody"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody></table></div>
  </div>

  <!-- PARTIDOS -->
  <div id="tabPartidos" class="tab-content" style="display:none">
    <div class="section-header"><div><h2>🏐 Partidos</h2></div><button class="btn btn-sm btn-primary" onclick="crearPartido()">➕ Nuevo</button></div>
    <div class="table-container"><table class="data-table"><thead><tr><th>Local</th><th>Visitante</th><th>Fecha</th><th>Resultado</th><th>Estado</th><th>Acción</th></tr></thead>
      <tbody id="partidosBody"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody></table></div>
  </div>

  <!-- NOTICIAS -->
  <div id="tabNoticias" class="tab-content" style="display:none">
    <div class="section-header"><div><h2>📰 Noticias</h2></div><button class="btn btn-sm btn-primary" onclick="crearNoticia()">➕ Nueva</button></div>
    <div class="table-container"><table class="data-table"><thead><tr><th>Título</th><th>Contenido</th><th>Autor</th><th>Destacado</th><th>Fecha</th><th>Acción</th></tr></thead>
      <tbody id="noticiasBody"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody></table></div>
  </div>

  <!-- SOCIOS -->
  <div id="tabSocios" class="tab-content" style="display:none">
    <div class="section-header"><div><h2>👥 Socios</h2></div><button class="btn btn-sm btn-primary" onclick="crearSocio()">➕ Añadir</button></div>
    <div class="table-container"><table class="data-table"><thead><tr><th>Nombre</th><th>Rol</th><th>Email</th><th>Teléfono</th><th>Activo</th><th>Acción</th></tr></thead>
      <tbody id="sociosBody"><tr><td colspan="6" class="loading-cell">Cargando...</td></tr></tbody></table></div>
  </div>

  <!-- SOLICITUDES -->
  <div id="tabSolicitudes" class="tab-content" style="display:none">
    <div class="section-header"><div><h2>📋 Solicitudes</h2></div></div>
    <div class="table-container"><table class="data-table"><thead><tr><th>Nombre</th><th>Email</th><th>Tipo</th><th>Mensaje</th><th>Estado</th><th>Fecha</th><th>Acción</th></tr></thead>
      <tbody id="solicitudesBody"><tr><td colspan="7" class="loading-cell">Cargando...</td></tr></tbody></table></div>
  </div>
</div>

<script>
function switchVC(btn, tabId) {
  document.querySelectorAll('[id^="tab"]').forEach(c => c.style.display = 'none');
  document.getElementById(tabId).style.display = 'block';
  document.querySelectorAll('.tab-btn').forEach(b => { b.style.color = 'var(--text-light)'; b.style.borderBottom = '3px solid transparent'; });
  btn.style.color = 'var(--p500)'; btn.style.borderBottom = '3px solid var(--p500)';
}
async function api(url, opts) {
  const r = await fetch(url, { headers:{'Content-Type':'application/json'}, ...opts });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

async function cargarDashboard() {
  try {
    const d = await api('/api/voley/dashboard');
    document.getElementById('statTorneos').textContent = d.torneos_activos ?? '—';
    document.getElementById('statPartidos').textContent = d.partidos_pendientes ?? '—';
    document.getElementById('statNoticias').textContent = d.noticias ?? '—';
    document.getElementById('statSocios').textContent = d.socios ?? '—';
    document.getElementById('statSolicitudes').textContent = d.solicitudes_pendientes ?? '—';
  } catch(e) {}
}

async function cargarTorneos() {
  try {
    const d = await api('/api/voley/torneos');
    document.getElementById('torneosBody').innerHTML = Array.isArray(d) && d.length
      ? d.map(t => '<tr><td><strong>'+t.nombre+'</strong></td><td>'+(t.descripcion||'')+'</td><td>'+(t.fecha_inicio||'')+'</td><td>'+(t.fecha_fin||'')+'</td><td><span class="badge badge-'+(t.estado==='activo'?'activo':'pendiente')+'">'+(t.estado||'')+'</span></td><td><button class="btn btn-sm btn-danger" onclick="eliminar(\'torneos\','+t.id+')">🗑️</button></td></tr>').join('')
      : '<tr><td colspan="6" class="loading-cell">Sin torneos</td></tr>';
  } catch(e) { document.getElementById('torneosBody').innerHTML = '<tr><td colspan="6" class="error-cell">Error al cargar</td></tr>'; }
}
async function crearTorneo() {
  const n=prompt('Nombre:'); if(!n)return;
  await api('/api/voley/torneos',{method:'POST',body:JSON.stringify({nombre:n,descripcion:prompt('Descripción:'),fecha_inicio:prompt('Fecha inicio:'),fecha_fin:prompt('Fecha fin:')})});
  cargarTorneos(); cargarDashboard();
}

async function cargarPartidos() {
  try {
    const d = await api('/api/voley/partidos');
    document.getElementById('partidosBody').innerHTML = Array.isArray(d) && d.length
      ? d.map(p => '<tr><td><strong>'+p.equipo_local+'</strong></td><td><strong>'+p.equipo_visitante+'</strong></td><td>'+(p.fecha||'')+'</td><td>'+(p.resultado_local!=null?p.resultado_local+'-'+p.resultado_visitante:'—')+'</td><td><span class="badge badge-'+(p.estado==='finalizado'?'activo':'pendiente')+'">'+(p.estado||'')+'</span></td><td>'+
        (p.estado==='pendiente'?'<button class="btn btn-sm btn-success" onclick="resultado('+p.id+')">📊</button> ':'')+
        '<button class="btn btn-sm btn-danger" onclick="eliminar(\'partidos\','+p.id+')">🗑️</button></td></tr>').join('')
      : '<tr><td colspan="6" class="loading-cell">Sin partidos</td></tr>';
  } catch(e) { document.getElementById('partidosBody').innerHTML = '<tr><td colspan="6" class="error-cell">Error</td></tr>'; }
}
async function crearPartido() {
  const l=prompt('Local:'),v=prompt('Visitante:'); if(!l||!v)return;
  await api('/api/voley/partidos',{method:'POST',body:JSON.stringify({equipo_local:l,equipo_visitante:v,fecha:prompt('Fecha:')})});
  cargarPartidos(); cargarDashboard();
}
async function resultado(id) {
  const l=prompt('Resultado local:'),v=prompt('Resultado visitante:');
  await api('/api/voley/partidos/'+id+'/resultado',{method:'PUT',body:JSON.stringify({resultado_local:parseInt(l),resultado_visitante:parseInt(v)})});
  cargarPartidos();
}

async function cargarNoticias() {
  try {
    const d = await api('/api/voley/noticias');
    document.getElementById('noticiasBody').innerHTML = Array.isArray(d) && d.length
      ? d.map(n => '<tr><td><strong>'+n.titulo+'</strong></td><td style="max-width:250px">'+(n.contenido||'').substring(0,100)+'</td><td>'+(n.autor||'')+'</td><td>'+(n.destacado?'⭐ Sí':'No')+'</td><td>'+(n.created_at?new Date(n.created_at).toLocaleDateString():'')+'</td><td><button class="btn btn-sm btn-danger" onclick="eliminar(\'noticias\','+n.id+')">🗑️</button></td></tr>').join('')
      : '<tr><td colspan="6" class="loading-cell">Sin noticias</td></tr>';
  } catch(e) { document.getElementById('noticiasBody').innerHTML = '<tr><td colspan="6" class="error-cell">Error</td></tr>'; }
}
async function crearNoticia() {
  const t=prompt('Título:'); if(!t)return;
  await api('/api/voley/noticias',{method:'POST',body:JSON.stringify({titulo:t,contenido:prompt('Contenido:'),destacado:confirm('¿Destacada?')})});
  cargarNoticias(); cargarDashboard();
}

async function cargarSocios() {
  try {
    const d = await api('/api/voley/socios');
    document.getElementById('sociosBody').innerHTML = Array.isArray(d) && d.length
      ? d.map(m => '<tr><td><strong>'+m.nombre+'</strong></td><td>'+(m.rol||'')+'</td><td>'+(m.email||'')+'</td><td>'+(m.telefono||'')+'</td><td>'+(m.activo?'✅ Sí':'❌ No')+'</td><td><button class="btn btn-sm btn-danger" onclick="eliminar(\'socios\','+m.id+')">🗑️</button></td></tr>').join('')
      : '<tr><td colspan="6" class="loading-cell">Sin socios</td></tr>';
  } catch(e) { document.getElementById('sociosBody').innerHTML = '<tr><td colspan="6" class="error-cell">Error</td></tr>'; }
}
async function crearSocio() {
  const n=prompt('Nombre:'); if(!n)return;
  await api('/api/voley/socios',{method:'POST',body:JSON.stringify({nombre:n,rol:prompt('Rol:'),email:prompt('Email:'),telefono:prompt('Teléfono:')})});
  cargarSocios(); cargarDashboard();
}

async function cargarSolicitudes() {
  try {
    const d = await api('/api/voley/solicitudes');
    document.getElementById('solicitudesBody').innerHTML = Array.isArray(d) && d.length
      ? d.map(s => '<tr><td>'+s.solicitante_nombre+'</td><td>'+(s.email||'')+'</td><td>'+(s.tipo||'')+'</td><td style="max-width:200px">'+(s.mensaje||'').substring(0,80)+'</td><td><span class="badge badge-'+(s.estado==='aprobado'?'activo':s.estado==='rechazado'?'suspendido':'pendiente')+'">'+s.estado+'</span></td><td>'+(s.created_at?new Date(s.created_at).toLocaleDateString():'')+'</td><td>'+
        (s.estado==='pendiente'?'<button class="btn btn-sm btn-success" onclick="gestionar('+s.id+',\'aprobado\')">✅</button><button class="btn btn-sm btn-danger" onclick="gestionar('+s.id+',\'rechazado\')">❌</button>':'—')+'</td></tr>').join('')
      : '<tr><td colspan="7" class="loading-cell">Sin solicitudes</td></tr>';
  } catch(e) { document.getElementById('solicitudesBody').innerHTML = '<tr><td colspan="7" class="error-cell">Error</td></tr>'; }
}
async function gestionar(id,est) {
  await api('/api/voley/solicitudes/estado',{method:'POST',body:JSON.stringify({solicitud_id:id,estado:est})});
  cargarSolicitudes(); cargarDashboard();
}

async function eliminar(col,id) {
  if(!confirm('¿Eliminar?')) return;
  await api('/api/voley/'+col+'/'+id,{method:'DELETE'});
  (window['cargar'+col.charAt(0).toUpperCase()+col.slice(1)]||function(){})();
  cargarDashboard();
}

document.addEventListener('DOMContentLoaded', () => {
  cargarDashboard(); cargarTorneos(); cargarPartidos(); cargarNoticias(); cargarSocios(); cargarSolicitudes();
});
</script>
