<div class="dashboard">
  <div class="dashboard-header">
    <h1>🆔 Administración PlacetaID</h1>
    <p class="dashboard-date">Gestión de identidades digitales · PLID26</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card stat-primary">
      <div class="stat-icon">👤</div>
      <div class="stat-content">
        <span class="stat-value" id="totalRegistros">—</span>
        <span class="stat-label">Registros</span>
        <span class="stat-detail">Identidades en PLID26</span>
      </div>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-icon">✅</div>
      <div class="stat-content">
        <span class="stat-value" id="totalActivos">—</span>
        <span class="stat-label">Activos</span>
        <span class="stat-detail">Cuentas operativas</span>
      </div>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-icon">🔒</div>
      <div class="stat-content">
        <span class="stat-value" id="totalBloqueados">—</span>
        <span class="stat-label">Bloqueados</span>
        <span class="stat-detail">Cuentas bloqueadas</span>
      </div>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-icon">📋</div>
      <div class="stat-content">
        <span class="stat-value" id="totalLogs">—</span>
        <span class="stat-label">Auditoría</span>
        <span class="stat-detail">Eventos registrados</span>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-header">
      <div>
        <h2>Acciones Rápidas</h2>
        <p class="section-desc">Gestión de identidades PlacetaID</p>
      </div>
    </div>
    <div class="quick-actions">
      <button class="action-card" onclick="cargarRegistros()">
        <span class="action-icon">🔄</span>
        <span class="action-title">Actualizar datos</span>
        <span class="action-desc">Refrescar registros y estadísticas</span>
      </button>
      <button class="action-card" onclick="cargarLogs()">
        <span class="action-icon">📋</span>
        <span class="action-title">Ver auditoría</span>
        <span class="action-desc">Eventos de autenticación recientes</span>
      </button>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--line);padding-bottom:0">
    <button class="tab-btn active" data-tab="tabRegistros" onclick="switchTabPlacetid(this,'tabRegistros')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--p500);border-bottom:3px solid var(--p500);margin-bottom:-2px;transition:var(--transition)">👤 Registros</button>
    <button class="tab-btn" data-tab="tabLogs" onclick="switchTabPlacetid(this,'tabLogs')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--text-light);transition:var(--transition)">📋 Auditoría</button>
    <button class="tab-btn" data-tab="tabSolicitantes" onclick="switchTabPlacetid(this,'tabSolicitantes');cargarSolicitantes()" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--text-light);transition:var(--transition)">🔌 Solicitantes</button>
    <button class="tab-btn" data-tab="tabConfig" onclick="switchTabPlacetid(this,'tabConfig')" style="padding:10px 20px;border:none;background:none;font-weight:600;font-size:14px;font-family:var(--font);cursor:pointer;color:var(--text-light);transition:var(--transition)">⚙️ Configuración</button>
  </div>

  <!-- Registros -->
  <div id="tabRegistros" class="tab-content">
    <div class="section-header">
      <div>
        <h2>👤 Identidades Registradas</h2>
        <p class="section-desc">Usuarios del sistema PlacetaID</p>
      </div>
      <input type="search" id="searchRegistro" oninput="filtrarRegistros()" placeholder="🔍 Buscar DIP, nombre..." style="width:220px;padding:8px 12px;border:2px solid var(--line);border-radius:var(--radius);font-family:var(--font);font-size:13px">
    </div>
    <div class="table-container">
      <table class="data-table" id="registrosTable">
        <thead>
          <tr><th>DIP</th><th>Nombre</th><th>Rol</th><th>Estado</th><th>2FA</th><th>Intentos</th><th>Registro</th><th>Acciones</th></tr>
        </thead>
        <tbody id="registrosBody"><tr><td colspan="8" class="loading-cell">Cargando registros...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- Solicitantes -->
  <div id="tabSolicitantes" class="tab-content" style="display:none">
    <div class="section-header"><div><h2>🔌 Aplicaciones integradas (Solicitantes)</h2><p class="section-desc">Registra apps que usarán PlacetaID como autenticación</p></div>
      <button class="btn btn-sm btn-primary" onclick="abrirModalCrearSolicitante()">➕ Nueva app</button>
    </div>
    <div class="table-container">
      <table class="data-table"><thead><tr><th>Nombre</th><th>Plataforma</th><th>Callback URL</th><th>API Key</th><th>Activo</th><th>Acciones</th></tr></thead>
        <tbody id="solicitantesBody"><tr><td colspan="7" class="loading-cell">Cargando...</td></tr></tbody>
      </table>
    </div>

    <!-- Modal crear/editar solicitante -->
    <div id="modalCrearSolicitante" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
      <div style="background:#fff;border-radius:16px;padding:28px;max-width:600px;width:90%;max-height:90vh;overflow-y:auto">
        <h3 style="margin:0 0 16px 0" id="modalCrearTitulo">🔌 Nueva aplicación PlacetaID</h3>
        <input type="hidden" id="solEditId" value="">
        <div style="display:grid;gap:12px">
          <label><strong>Nombre *</strong><input type="text" id="solNombre" class="form-input" placeholder="Mi App"></label>
          <label><strong>Descripción</strong><textarea id="solDesc" class="form-input" rows="2" placeholder="Descripción de la aplicación"></textarea></label>
          <label><strong>URL de origen / Callback *</strong><input type="text" id="solUrl" class="form-input" placeholder="https://miapp.com/callback"></label>
          <label><strong>Redirect URIs adicionales</strong><textarea id="solRedirectUris" class="form-input" rows="2" placeholder="https://miapp.com/callback2&#10;https://miapp.com/callback3"></textarea></label>
          <label><strong>Plataforma</strong>
            <select id="solPlataforma" class="form-input">
              <option value="web">Web</option>
              <option value="android">Android</option>
              <option value="ios">iOS</option>
              <option value="desktop">Desktop</option>
              <option value="multiplataforma">Multiplataforma</option>
              <option value="backend">Backend</option>
            </select>
          </label>
          <label><strong>Color de tema (bgColor)</strong><input type="text" id="solColor" class="form-input" placeholder="#3f00d8" value="#3f00d8"></label>
          <label><strong>Logo URL (opcional)</strong><input type="text" id="solLogo" class="form-input" placeholder="https://.../logo.png"></label>
          <label><strong>Scheme (Android/iOS)</strong><input type="text" id="solScheme" class="form-input" placeholder="miapp://"></label>
          <label><strong>Package / Bundle ID</strong><input type="text" id="solPackage" class="form-input" placeholder="com.miapp.android"></label>
          <div style="display:flex;gap:12px;flex-wrap:wrap">
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer"><input type="checkbox" id="solPKCE" checked> PKCE requerido</label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer"><input type="checkbox" id="solWebFallback" checked> Permitir fallback web</label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer"><input type="checkbox" id="solActivo" checked> Activo</label>
          </div>
          <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
            <button class="btn btn-secondary" onclick="cerrarModalCrearSolicitante()">Cancelar</button>
            <button class="btn btn-primary" id="btnCrearEditarSolicitante" onclick="guardarSolicitante()">💾 Crear aplicación</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal detalle solicitante (API Key + instrucciones) -->
    <div id="modalDetalleSolicitante" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
      <div style="background:#fff;border-radius:16px;padding:28px;max-width:700px;width:90%;max-height:90vh;overflow-y:auto">
        <h3 style="margin:0 0 16px 0" id="detalleTitulo">🔌 Detalle de aplicación</h3>
        <div id="detalleContent"></div>
        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px">
          <button class="btn btn-secondary" onclick="cerrarModalDetalle()">Cerrar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Logs -->
  <div id="tabLogs" class="tab-content" style="display:none">
    <div class="section-header">
      <div>
        <h2>📋 Auditoría</h2>
        <p class="section-desc">Eventos de autenticación y actividad</p>
      </div>
      <button class="btn btn-sm btn-primary" onclick="cargarLogs()">🔄 Refrescar</button>
    </div>
    <div class="table-container">
      <table class="data-table" id="logsTable">
        <thead>
          <tr><th>Fecha</th><th>DIP</th><th>Evento</th><th>Servicio</th><th>IP</th><th>Fase</th></tr>
        </thead>
        <tbody id="logsBody"><tr><td colspan="6" class="loading-cell">Cargando logs...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- Config -->
  <div id="tabConfig" class="tab-content" style="display:none">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-content">
          <span class="stat-label">API Key PlacetaID</span>
          <div style="display:flex;gap:8px;align-items:center;margin-top:8px">
            <code style="flex:1;padding:10px;background:var(--bg);border-radius:8px;font-size:12px;word-break:break-all" id="apiKeyDisplay">ccb611655030bdadf7218418dc195dcb</code>
            <button class="btn btn-sm btn-primary" onclick="copiarAlPortapapeles('ccb611655030bdadf7218418dc195dcb', 'API Key copiada')">📋 Copiar</button>
          </div>
          <span class="stat-detail" style="margin-top:6px">Callback: https://grupodelaplaceta.vercel.app/placetid/callback</span>
          <span class="stat-detail" style="margin-top:6px">Proxy activo: /api/admin/placetid · Estado: <span id="placetidStatus" style="font-weight:600;color:var(--warning)">⏳ Pendiente</span></span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-content">
          <span class="stat-label">Endpoint PLID26</span>
          <p style="margin-top:8px;font-size:13px">https://id.laplaceta.org</p>
          <span class="stat-detail">Versión API v1 · Integración OAuth2</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let registrosData = [];

  function switchTabPlacetid(btn, tabId) {
    document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
    document.getElementById(tabId).style.display = 'block';
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.style.color = 'var(--text-light)'; b.style.borderBottom = '3px solid transparent'; b.style.marginBottom = '-2px';
    });
    btn.style.color = 'var(--p500)'; btn.style.borderBottom = '3px solid var(--p500)';
  }

  async function apiPlacetid(endpoint, opts = {}) {
    const base = '/api/admin/placetid';
    const path = endpoint.replace('/admin/', '/');
    const r = await fetch(base + path, opts);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  }

  async function cargarRegistros() {
    try {
      const data = await apiPlacetid('/registros');
      registrosData = Array.isArray(data.registros) ? data.registros : Array.isArray(data) ? data : [];
      const activos = registrosData.filter(r => r.activo && !r.bloqueado).length;
      const bloqueados = registrosData.filter(r => r.bloqueado || r.banned).length;
      document.getElementById('totalRegistros').textContent = registrosData.length;
      document.getElementById('totalActivos').textContent = activos;
      document.getElementById('totalBloqueados').textContent = bloqueados;

      const tbody = document.getElementById('registrosBody');
      if (!registrosData.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="loading-cell">Sin registros</td></tr>';
        return;
      }
      tbody.innerHTML = registrosData.map(r => {
        const estClass = r.bloqueado || r.banned ? 'badge-suspendido' : r.activo ? 'badge-activo' : 'badge-baja';
        const estLabel = r.bloqueado || r.banned ? 'Bloqueado' : r.activo ? 'Activo' : 'Inactivo';
        const tfaClass = r.totpVerified ? 'badge-activo' : 'badge-pendiente';
        const tfaLabel = r.totpVerified ? '✅ Sí' : '❌ No';
        return '<tr>' +
          '<td><strong>' + (r.dip || '—') + '</strong></td>' +
          '<td>' + (r.nombre || '') + ' ' + (r.apellidos || '') + '</td>' +
          '<td><span class="pill pill-purple">' + (r.rol || 'miembro') + '</span></td>' +
          '<td><span class="badge ' + estClass + '">' + estLabel + '</span></td>' +
          '<td><span class="badge ' + tfaClass + '">' + tfaLabel + '</span></td>' +
          '<td>' + (r.intentosFallidos || 0) + '</td>' +
          '<td>' + (r.createdAt ? new Date(r.createdAt).toLocaleDateString('es-ES') : '—') + '</td>' +
          '<td style="display:flex;gap:4px">' +
            (r.bloqueado ? '<button class="btn btn-success btn-sm" onclick="desbloquear(\'' + r.dip + '\')">🔓</button>' : '') +
            (!r.bloqueado ? '<button class="btn btn-warning btn-sm" onclick="toggleActivo(\'' + r.dip + '\')">' + (r.activo ? '🔒' : '🔓') + '</button>' : '') +
          '</td></tr>';
      }).join('');
    } catch (e) {
      document.getElementById('registrosBody').innerHTML = '<tr><td colspan="8" class="error-cell">Error: ' + (e.message || 'conexión') + '</td></tr>';
    }
  }

  function filtrarRegistros() {
    const q = document.getElementById('searchRegistro').value.toLowerCase();
    document.querySelectorAll('#registrosBody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  }

  async function cargarLogs() {
    try {
      const data = await apiPlacetid('/admin/logs?limit=50');
      const logs = Array.isArray(data.logs) ? data.logs : Array.isArray(data) ? data : [];
      document.getElementById('totalLogs').textContent = logs.length;
      const tbody = document.getElementById('logsBody');
      if (!logs.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="loading-cell">Sin logs</td></tr>';
        return;
      }
      tbody.innerHTML = logs.map(l => {
        const evClass = l.evento === 'intento_exitoso' ? 'badge-activo' : l.evento === 'error_credenciales' || l.evento === 'error_2fa' ? 'badge-suspendido' : 'badge-pendiente';
        return '<tr>' +
          '<td>' + (l.timestamp ? new Date(l.timestamp).toLocaleString('es-ES') : '—') + '</td>' +
          '<td><strong>' + (l.dip || '—') + '</strong></td>' +
          '<td><span class="badge ' + evClass + '">' + (l.evento || '—') + '</span></td>' +
          '<td>' + (l.servicio || '—') + '</td>' +
          '<td style="font-size:11px;font-family:monospace">' + (l.ip || '—') + '</td>' +
          '<td>' + (l.fase || '—') + '</td></tr>';
      }).join('');
    } catch (e) {
      document.getElementById('logsBody').innerHTML = '<tr><td colspan="6" class="error-cell">Error: ' + (e.message || 'conexión') + '</td></tr>';
    }
  }

  async function desbloquear(dip) {
    try {
      await apiPlacetid('/admin/desbloquear/' + dip, { method: 'POST' });
      mostrarToast('success', '✅ DIP ' + dip + ' desbloqueado');
      cargarRegistros();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  async function toggleActivo(dip) {
    try {
      await apiPlacetid('/admin/toggle/' + dip, { method: 'POST' });
      mostrarToast('success', '✅ Estado cambiado para ' + dip);
      cargarRegistros();
    } catch (e) { mostrarToast('error', 'Error: ' + e.message); }
  }

  async function checkStatus() {
    const statusEl = document.getElementById('placetidStatus');
    try {
      const r = await fetch('/api/admin/placetid/stats');
      if (r.ok) { statusEl.textContent = '✅ Conectado'; statusEl.style.color = 'var(--success)'; }
      else { statusEl.textContent = '⚠️ Error ' + r.status; statusEl.style.color = 'var(--danger)'; }
    } catch(e) {
      statusEl.textContent = '❌ Sin conexión';
      statusEl.title = e.message;
    }
  }

  // ── SOLICITANTES ──────────────────────────────────────────────────────────
  async function cargarSolicitantes() {
    try {
      const d = await apiPlacetid('/solicitantes');
      const lista = Array.isArray(d) ? d : Array.isArray(d.solicitantes) ? d.solicitantes : [];
      const tbody = document.getElementById('solicitantesBody');
      if (!lista.length) { tbody.innerHTML = '<tr><td colspan="6" class="loading-cell">Sin aplicaciones registradas</td></tr>'; return; }
      tbody.innerHTML = lista.map(s => '<tr>' +
        '<td><strong>' + (s.nombre || '—') + '</strong></td>' +
        '<td><span class="pill pill-purple">' + (s.plataforma || '—') + '</span></td>' +
        '<td style="font-size:12px;max-width:200px;overflow:hidden;text-overflow:ellipsis" title="' + (s.urlOrigen || '') + '">' + (s.urlOrigen || '—') + '</td>' +
        '<td><code style="font-size:11px;padding:3px 6px;background:var(--bg);border-radius:4px">' + (s.apiKey ? s.apiKey.slice(0,16) + '…' : '—') + '</code></td>' +
        '<td><span class="badge badge-' + (s.activo !== false ? 'activo' : 'suspendido') + '">' + (s.activo !== false ? '✅' : '❌') + '</span></td>' +
        '<td style="display:flex;gap:4px">' +
          '<button class="btn btn-sm btn-outline" onclick="verSolicitante(\'' + s._id + '\')" title="Ver detalle">🔍</button>' +
          '<button class="btn btn-sm btn-outline" onclick="editarSolicitante(\'' + s._id + '\')" title="Editar" style="color:var(--p500)">✏️</button>' +
        '</td></tr>'
      ).join('');
    } catch(e) { document.getElementById('solicitantesBody').innerHTML = '<tr><td colspan="7" class="error-cell">Error: ' + (e.message||'') + '</td></tr>'; }
  }

  // ── Editar solicitante ────────────────────────────────────────────────────
  async function editarSolicitante(id) {
    try {
      const d = await apiPlacetid('/solicitantes/' + id);
      const s = d.solicitante || d;
      document.getElementById('modalCrearTitulo').textContent = '✏️ Editar: ' + (s.nombre || 'App');
      document.getElementById('solEditId').value = s._id;
      document.getElementById('solNombre').value = s.nombre || '';
      document.getElementById('solDesc').value = s.descripcion || '';
      document.getElementById('solUrl').value = s.urlOrigen || '';
      document.getElementById('solRedirectUris').value = Array.isArray(s.redirectUris) ? s.redirectUris.join('\n') : (s.redirectUris || '');
      document.getElementById('solPlataforma').value = s.plataforma || 'web';
      document.getElementById('solColor').value = s.bgColor || '#3f00d8';
      document.getElementById('solLogo').value = s.logo || '';
      document.getElementById('solScheme').value = s.appScheme || '';
      document.getElementById('solPackage').value = s.packageName || '';
      document.getElementById('solPKCE').checked = s.pkceRequired !== false;
      document.getElementById('solWebFallback').checked = s.permitirWebFallback !== false;
      document.getElementById('solActivo').checked = s.activo !== false;
      document.getElementById('btnCrearEditarSolicitante').textContent = '💾 Guardar cambios';
      document.getElementById('modalCrearSolicitante').style.display = 'flex';
    } catch(e) { alert('Error: ' + e.message); }
  }

  function abrirModalCrearSolicitante() {
    document.getElementById('modalCrearTitulo').textContent = '🔌 Nueva aplicación PlacetaID';
    document.getElementById('solEditId').value = '';
    document.getElementById('solNombre').value = '';
    document.getElementById('solDesc').value = '';
    document.getElementById('solUrl').value = '';
    document.getElementById('solRedirectUris').value = '';
    document.getElementById('solPlataforma').value = 'web';
    document.getElementById('solColor').value = '#3f00d8';
    document.getElementById('solLogo').value = '';
    document.getElementById('solScheme').value = '';
    document.getElementById('solPackage').value = '';
    document.getElementById('solPKCE').checked = true;
    document.getElementById('solWebFallback').checked = true;
    document.getElementById('solActivo').checked = true;
    document.getElementById('btnCrearEditarSolicitante').textContent = '💾 Crear aplicación';
    document.getElementById('modalCrearSolicitante').style.display = 'flex';
  }
  function cerrarModalCrearSolicitante() { document.getElementById('modalCrearSolicitante').style.display = 'none'; }
  function cerrarModalDetalle() { document.getElementById('modalDetalleSolicitante').style.display = 'none'; }

  async function guardarSolicitante() {
    const nombre = document.getElementById('solNombre').value.trim();
    const url = document.getElementById('solUrl').value.trim();
    if (!nombre || !url) return alert('Nombre y URL son obligatorios');
    const editId = document.getElementById('solEditId').value;
    const redirectUrisRaw = document.getElementById('solRedirectUris').value.trim();
    const redirectUris = redirectUrisRaw ? redirectUrisRaw.split('\n').map(u => u.trim()).filter(Boolean) : [url];

    try {
      const body = {
        nombre,
        descripcion: document.getElementById('solDesc').value.trim(),
        urlOrigen: url,
        redirectUris,
        plataforma: document.getElementById('solPlataforma').value,
        bgColor: document.getElementById('solColor').value.trim() || '#3f00d8',
        logo: document.getElementById('solLogo').value.trim() || undefined,
        appScheme: document.getElementById('solScheme').value.trim() || undefined,
        packageName: document.getElementById('solPackage').value.trim() || undefined,
        pkceRequired: document.getElementById('solPKCE').checked,
        permitirWebFallback: document.getElementById('solWebFallback').checked,
        activo: document.getElementById('solActivo').checked
      };

      let r, data;
      if (editId) {
        r = await fetch('/api/admin/placetid/solicitantes/' + editId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        data = await r.json();
        if (!r.ok) return alert('❌ Error: ' + (data.error || data.message || r.status));
        cerrarModalCrearSolicitante();
        alert('✅ Solicitante actualizado correctamente');
      } else {
        r = await fetch('/api/admin/placetid/solicitantes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        data = await r.json();
        if (!r.ok) return alert('❌ Error: ' + (data.error || data.message || r.status));
        cerrarModalCrearSolicitante();
        if (data.solicitante && data.solicitante._id) verSolicitante(data.solicitante._id);
        else if (data._id) verSolicitante(data._id);
        else alert('✅ Solicitante creado.');
      }
      cargarSolicitantes();
    } catch(e) { alert('❌ Error: ' + e.message); }
  }

  document.addEventListener('DOMContentLoaded', function() {
    checkStatus();
    cargarRegistros();
    cargarLogs();
  });
</script>
