<div class="dashboard">
  <div class="dashboard-header">
    <h1>👥 Ciudadanos</h1>
    <p class="dashboard-date">Padrón de ciudadanos y gestión de solicitantes</p>
  </div>

  <div class="stats-grid" id="statsGrid">
    <div class="stat-card stat-primary"><div class="stat-icon">👥</div><div class="stat-content"><span class="stat-value" id="totalCiudadanos">—</span><span class="stat-label">Total</span></div></div>
    <div class="stat-card stat-success"><div class="stat-icon">✅</div><div class="stat-content"><span class="stat-value" id="totalActivos">—</span><span class="stat-label">Activos</span></div></div>
    <div class="stat-card stat-warning"><div class="stat-icon">⏳</div><div class="stat-content"><span class="stat-value" id="totalPendientes">—</span><span class="stat-label">Pendientes</span></div></div>
    <div class="stat-card stat-info"><div class="stat-icon">📄</div><div class="stat-content"><span class="stat-value" id="totalTramites">—</span><span class="stat-label">Trámites</span></div></div>
  </div>

  <div class="section-header"><div><h2>Listado de Ciudadanos</h2></div>
    <input type="search" id="searchCiudadanos" oninput="filtrarTabla('searchCiudadanos','ciudadanosBody')" placeholder="🔍 Buscar por DIP, nombre..." style="width:260px;padding:8px 12px;border:2px solid var(--line);border-radius:var(--radius);font-family:var(--font);font-size:13px">
    <button class="btn btn-sm btn-primary" onclick="cargarCiudadanos()">🔄 Refrescar</button>
  </div>
  <div class="table-container"><table class="data-table"><thead><tr><th>DIP</th><th>Nombre</th><th>Alias</th><th>PlacetaID</th><th>Email</th><th>Teléfono</th><th>Rol</th><th>Estado</th><th>Trámites</th></tr></thead>
    <tbody id="ciudadanosBody"><tr><td colspan="9" class="loading-cell">Cargando...</td></tr></tbody></table></div>
</div>

<script>
async function apiFetch(url, opts) {
  const r = await fetch(url, { headers: { 'Content-Type': 'application/json' }, ...opts });
  if (!r.ok) { let m = 'HTTP ' + r.status; try { const e = await r.json(); if (e.error) m += ': ' + e.error; } catch {} throw new Error(m); }
  return r.json();
}
function filtrarTabla(searchId, tbodyId) {
  const q = document.getElementById(searchId).value.toLowerCase();
  document.querySelectorAll(`#${tbodyId} tr`).forEach(r => r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none');
}
async function cargarCiudadanos() {
  try {
    const d = await apiFetch('/api/admin/tramites/ciudadanos');
    const tbody = document.getElementById('ciudadanosBody');
    document.getElementById('totalCiudadanos').textContent = d.length;
    document.getElementById('totalActivos').textContent = d.filter(u => u.estado === 'activo').length;
    document.getElementById('totalPendientes').textContent = d.filter(u => u.estado === 'pendiente' || u.estado === 'suspendido').length;
    document.getElementById('totalTramites').textContent = d.reduce((s, u) => s + (u.total_tramites || 0), 0);
    if (!d.length) { tbody.innerHTML = '<tr><td colspan="9" class="loading-cell">Sin ciudadanos</td></tr>'; return; }
    tbody.innerHTML = d.map(u => '<tr>' +
      '<td><strong>' + (u.dip || '—') + '</strong></td>' +
      '<td>' + (u.nombre_real || '—') + '</td>' +
      '<td>' + (u.alias || '—') + '</td>' +
      '<td>' + (u.placeid || '—') + '</td>' +
      '<td>' + (u.email || '—') + '</td>' +
      '<td>' + (u.telefono || '—') + '</td>' +
      '<td><span class="pill pill-purple">' + (u.rol || 'miembro') + '</span></td>' +
      '<td><span class="badge badge-' + (u.estado === 'activo' ? 'activo' : u.estado === 'pendiente' ? 'pendiente' : 'suspendido') + '">' + (u.estado || '—') + '</span></td>' +
      '<td>' + (u.total_tramites || 0) + '</td></tr>'
    ).join('');
  } catch(e) { document.getElementById('ciudadanosBody').innerHTML = '<tr><td colspan="9" class="error-cell">' + e.message + '</td></tr>'; }
}
document.addEventListener('DOMContentLoaded', cargarCiudadanos);
</script>
