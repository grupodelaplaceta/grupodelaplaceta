      <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:2rem;margin-bottom:8px">
        <span style="color:#FF3333">¡</span><span style="color:#FF6600">U</span><span style="color:#D6CE52">p</span><span style="color:#336E45">s</span><span style="color:#3A00E1">!</span>
      </h1>
      <p style="opacity:0.8;margin-bottom:24px"><%= error || 'Página no encontrada' %></p>
      <a href="/" class="btn-hero btn-hero-primary" style="display:inline-flex">← Volver a inicio</a>
    </div>
  </div>
</body>
</html>
